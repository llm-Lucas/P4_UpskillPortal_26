@page "/Modulos"

@inject IModuloData moduloData
@inject ICursoData cursoData

<div class="cardstyle">
    <h2>@Title</h2>

    @if (Mode == "Add")
    {

    }
    else
    {
        <RadzenButton class="my-4" ButtonStyle="ButtonStyle.Primary" Text="Criar Módulo" Icon="add" Click="@(() => navManager.NavigateTo("Modulo"))" />
    }

    <div class="d-flex align-items-center mb-3" style="gap: 12px;">
        <span style="font-weight: 500; white-space: nowrap;">Filtrar por curso:</span>
        <RadzenDropDown @bind-Value="@cursoFiltroSelecionado"
                        Data="@cursosFiltro"
                        TextProperty="Label"
                        ValueProperty="Value"
                        Change="@OnCursoFiltroChanged"
                        Style="width: 280px;" />
    </div>

    <RadzenGrid Data="@modulosFiltrados"
                TItem="Modulo"
                AllowSorting="true"
                AllowFiltering="true"
                FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                AllowPaging="true"
                PageSize="10">
        <Columns>
            <RadzenGridColumn TItem="Modulo" Property="Nome" Title="Nome" />
            <RadzenGridColumn TItem="Modulo" Property="Horas" Title="Duração em Horas" Sortable="false" Filterable="false" />

            @if (Mode == "Add")
            {
                <RadzenGridColumn Title="Adicionar" TItem="Modulo" Sortable="false" Filterable="false">
                    <Template Context="Modulo">
                        <RadzenButton Title="Associar Módulo" Size="ButtonSize.Medium" ButtonStyle="ButtonStyle.Secondary" Icon="add" Click="@(() => SendModulo(Modulo.Id))" />
                    </Template>
                </RadzenGridColumn>
            }
            else
            {
                <RadzenGridColumn Title="Opções" TItem="Modulo" Sortable="false" Filterable="false">
                    <Template Context="Modulo">
                        <RadzenButton Title="Ver detalhes" Size="ButtonSize.Medium" Icon="description" Click=@(args => dialogService.Open<DetalhesModulo>($"Detalhes",
                                                                                                                                 new Dictionary<string, object>() { { "ModuloId", Modulo.Id } },
                                                                                                                                 new DialogOptions() { Width = "80%", Height = "90%" })) />
                        <RadzenButton Title="Editar" Size="ButtonSize.Medium" ButtonStyle="ButtonStyle.Secondary" Icon="mode_edit" Click="@(() => navManager.NavigateTo($"Modulo/{Modulo.Id}"))" />
                        <RadzenButton Title="Remover" Size="ButtonSize.Medium" ButtonStyle="ButtonStyle.Danger" Icon="delete" Click="@(() => ConfirmDelete(Modulo))" />
                    </Template>
                </RadzenGridColumn>
            }
        </Columns>
    </RadzenGrid>
</div>

@if (!IsViewedAsChild)
{
    <div class="row justify-content-center">
        <div class="col-md-12 d-flex align-items-end justify-content-center" style="margin-top: 16px;">
            <RadzenButton ButtonStyle="ButtonStyle.Secondary" Icon="cancel" style="display: inline-block; margin-left: 10px;" Text="Voltar" Click="@(() => navManager.NavigateTo($"Index"))" />
        </div>
    </div>
    <br />
}

@code {

    List<Modulo> todosModulos;
    List<Modulo> modulosFiltrados;
    int? cursoFiltroSelecionado = null; // null = "Todos"

    class CursoFiltroOption
    {
        public string Label { get; set; }
        public int? Value { get; set; }
    }

    List<CursoFiltroOption> cursosFiltro = new();

    [Parameter]
    public bool IsViewedAsChild { get; set; }

    [Parameter]
    public string Mode { get; set; }

    [Parameter]
    public string Title { get; set; } = "Módulos";

    [Parameter]
    public EventCallback<int> OutgoingModulo { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Carregar cursos para o dropdown dinamicamente
        var cursos = cursoData.GetAll().OrderBy(c => c.Nome).ToList();
        cursosFiltro.Add(new CursoFiltroOption { Label = "Todos", Value = null });
        foreach (var curso in cursos)
        {
            cursosFiltro.Add(new CursoFiltroOption { Label = curso.Nome, Value = curso.Id });
        }

        LoadModulos();
    }

    void LoadModulos()
    {
        todosModulos = moduloData.GetAll().OrderBy(m => m.Nome).ToList();
        modulosFiltrados = todosModulos;
    }

    void OnCursoFiltroChanged(object value)
    {
        if (value == null)
        {
            // "Todos" selecionado
            modulosFiltrados = todosModulos;
        }
        else
        {
            int cursoId = (int)value;
            modulosFiltrados = moduloData.GetModulosByCurso(cursoId)
                                         .OrderBy(m => m.Nome)
                                         .ToList();
        }
    }

    private async Task SendModulo(int ToSendId)
    {
        await OutgoingModulo.InvokeAsync(ToSendId);
    }

    async Task ConfirmDelete(Modulo modulo)
    {
        await dialogService.OpenAsync("Confimar apagar", ds =>
        @<div>
            <p>Tem a certeza que pretende apagar @modulo.Nome?</p>
            <p class="mb1 text-danger">Esta acção é irreversível.</p>
            <div class="row">
                <div class="col-md-12 d-flex justify-content-center">
                    <RadzenButton class="w-150 mx-2" Text="Ok" Click="() => { moduloData.Remove(modulo.Id); ds.Close(true); LoadModulos(); }" />
                    <RadzenButton class="w-150 mx-2" Text="Cancel" Click="() => ds.Close(false)" ButtonStyle="ButtonStyle.Secondary" />
                </div>
            </div>
        </div>);
    }
}