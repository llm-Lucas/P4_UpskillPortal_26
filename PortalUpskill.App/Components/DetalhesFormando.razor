@page "/Detalhes/Formando/{FormandoId:int}"

@inject IFormandoData FormandoData
@inject IModuloData moduloData
@inject ICNAEFData CNAEFData
@inject IHabilitacoesData HabilitacoesData
@inject IPaisesData PaisesData
@inject FileManagerService FileMngSrv
@inject IJSRuntime JSRuntime

@inject IFaltaData FaltaData

<span>Nome Completo:</span>
<h2>@formando.Nome</h2>

<a href="/Index" style="display:inline-flex; align-items:center; gap:6px; color:#0D28C2; font-weight:500; margin-bottom:1rem; text-decoration:none;">
    <span class="material-icons">arrow_back</span>
    Voltar
</a>

@*INICIO #008*@
@*Fotografia do Formando*@
<br />
<div>
    <img src="@foto" width="100" alt="" style="margin-top:1em;" />
</div>

@*Botao para download do CV*@
@*Falta adicionar Logica no DownloadCv*@
<RadzenButton Text="Download CV" Icon="" Click="@DownloadCv" Style="margin-bottom:20px" />
@*FIM #008*@

<br />
<span class="material-icons" style="vertical-align: middle; padding-top:-3px; color:blue;">email</span><a href="@email">Enviar email</a>

<AuthorizeView Roles="Administrador, Secretariado">
    <Authorized>
        <RadzenCard Style="margin-bottom: 20px;">
            <div class="row">
                <div class="col-md-6">
                    <div>Data de Nascimento:</div>
                    <b>@String.Format("{0:d}", formando.DataNascimento)</b>
                    <div style="margin-top:20px">Email:</div>
                    <b>@formando.Email</b>
                    <div style="margin-top:20px">Género:</div>
                    <b>@formando.Sexo</b>
                    <div style="margin-top:20px">Cartão de Cidadão:</div>
                    <b>@formando.CC</b>
                    <div style="margin-top:20px">NIF:</div>
                    <b>@formando.NIF</b>
                    <div style="margin-top:20px">Contacto Telemóvel:</div>
                    <b>@formando.ContactoTelemovel</b>
                    <div style="margin-top:20px">Contacto Telefone:</div>
                    <b>@formando.ContactoTelefone</b>
                    <br />
                    <img src="@foto" width="100" alt="" style="margin-top:1em;" />
                </div>
                <div class="col-md-6">
                    <div>Morada:</div>
                    <b>@formando.Morada</b>
                    <div style="margin-top:20px">Código Postal:</div>
                    <b>@formando.CP</b>
                    <div style="margin-top:20px">IBAN:</div>
                    <b>@formando.IBAN</b>
                    <div style="margin-top:20px">CNAEF:</div>
                    <b>@cnaef</b>
                    <div style="margin-top:20px">Habilitações Literárias:</div>
                    <b>@habilitacoesLiterarias</b>
                    <div style="margin-top:20px">Nacionalidade:</div>
                    <b>@nacionalidade</b>
                    <div style="margin-top:20px">Tem Bolsa:</div>
                    @if (formando.Bolsa)
                    {
                        <b>Sim</b>
                    }
                    else
                    {
                        <b>Não</b>
                    }
                    <div style="margin-top:20px">Estado:</div>
                    <b>@formando.Estado.Nome</b>
                    <br />
                    @if (formando.CV != null)
                    {
                        <RadzenButton Click="VisualizarCV" Text="Visualizar o currículo" Style="margin-top:1em;" />
                    }
                </div>
            </div>

            <div class="row" style="margin-top:1em;">
                <div class="col-md-12">
                    <h3>Situação Académica</h3>
                    @if (formando.Turma != null)
                    {
                        <div class="row">
                            <div class="col-md-12">
                                <p><b>Curso:</b> @formando.Turma.Curso.Nome</p>
                                <p><b>Turma:</b> @formando.Turma.Nome</p>
                                <p><b>Data de Início:</b> @String.Format("{0:d}", formando.Turma.DataInicioCurso)</p>
                                <p><b>Data de Fim:</b> @String.Format("{0:d}", formando.Turma.DataFimCurso)</p>
                                <p><b>Módulos:</b></p>
                                <ul>
                                    @foreach (Modulo modulo in modulos)
                                    {
                                        string sigla = $"M{@modulo.Id}";

                                        <li><b>@sigla</b> - @modulo.Nome - @modulo.Formador.Nome</li>
                                    }
                                </ul>
                            </div>
                        </div>

                        <RadzenGrid Data="@formandos"
                        TItem="Formando"
                        AllowSorting="true"
                        AllowFiltering="true"
                        FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                        AllowPaging="true"
                        PageSize="10">
                            <Columns>
                                <RadzenGridColumn TItem="Formando" Title="FJ*">
                                    <Template Context="Formando">
                                        @if (Formando.FaltaJustificadas != null)
                                        {
                                            <span>@((Formando.FaltaJustificadas.Duracao / 60.0 / Formando.Turma.Curso.DuracaoHoras * 100).ToString("0.##"))%</span>
                                        }
                                        else
                                        {
                                            <span>0%</span>
                                        }
                                    </Template>
                                    <FooterTemplate>
                                        <i>*Faltas Justificadas</i>
                                    </FooterTemplate>
                                </RadzenGridColumn>
                                <RadzenGridColumn TItem="Formando" Title="FI*">
                                    <Template Context="Formando">
                                        @if (Formando.FaltaInjustificadas != null)
                                        {
                                            <span>@((Formando.FaltaInjustificadas.Duracao / 60.0 / Formando.Turma.Curso.DuracaoHoras * 100).ToString("0.##"))%</span>
                                        }
                                        else
                                        {
                                            <span>0%</span>
                                        }
                                    </Template>
                                    <FooterTemplate>
                                        <i>*Faltas Injustificadas</i>
                                    </FooterTemplate>
                                </RadzenGridColumn>

                                @for (int i = 0; i < modulos.Count(); i++)
                                {
                                    int index = i;
                                    string title = $"Média M{modulos[index].Id}";

                                    <RadzenGridColumn TItem="Formando" Property="" Title="@title">
                                        <Template Context="Formando">
                                            @if (Formando.DictAvaliacaoModular.Count() != 0)
                                            {
                                                @if (Formando.DictAvaliacaoModular.ContainsKey(modulos[index].Id) && Formando.DictAvaliacaoModular[modulos[index].Id].NotaFinal >= 10)
                                                {
                                                    <span style='color:green'>@(Formando.DictAvaliacaoModular[modulos[index].Id].NotaFinal.ToString("0.##"))</span>
                                                }
                                                else if (Formando.DictAvaliacaoModular.ContainsKey(modulos[index].Id) && Formando.DictAvaliacaoModular[modulos[index].Id].NotaFinal < 10)
                                                {
                                                    <span style='color:red'>@(Formando.DictAvaliacaoModular[modulos[index].Id].NotaFinal.ToString("0.##")) </span>
                                                }
                                                else
                                                {
                                                    <span>Sem nota</span>
                                                }
                                            }
                                            else
                                            {
                                                <span>Sem nota</span>
                                            }
                                        </Template>
                                    </RadzenGridColumn>
                                }

                                <RadzenGridColumn TItem="Formando" Property="" Title="Nota Final">
                                    <Template Context="Formando">
                                        @if (Formando.AvaliacaoFinal != null && Formando.AvaliacaoFinal.NotaFinal >= 10)
                                        {
                                            <span style='color:darkgreen'>@(Formando.AvaliacaoFinal.NotaFinal.ToString("0.##"))</span>
                                        }
                                        else if (Formando.AvaliacaoFinal != null && Formando.AvaliacaoFinal.NotaFinal < 10)
                                        {
                                            <span style='color:red'>@(Formando.AvaliacaoFinal.NotaFinal.ToString("0.##"))</span>
                                        }
                                        else
                                        {
                                            <span>Sem nota</span>
                                        }
                                    </Template>
                                </RadzenGridColumn>

                            </Columns>
                        </RadzenGrid>
                    }
                    else
                    {
                        <h5>O formando ainda não está associado a uma Turma.</h5>
                    }
                </div>
            </div>

            @*INICIO #008*@
            @*Adicionar uma tabela com duas colunas*@
            @*Uma coluna que mostra as datas das Faltas Justificadas, e outra que mostra a data das Faltas Injustificadas*@
            <div class="row" style="margin-top:1em;">
                <div class="col-md-12">
                    <h3>Faltas</h3>
                    <RadzenGrid Data="@GetFaltasList()" TItem="FaltaDisplay" AllowPaging="true" PageSize="10">
                        <Columns>
                            <RadzenGridColumn TItem="FaltaDisplay" Title="Data" Property="Data">
                                <Template Context="falta">
                                    @falta.Data.ToString("dd/MM/yyyy")
                                </Template>
                            </RadzenGridColumn>
                            <RadzenGridColumn TItem="FaltaDisplay" Title="Tipo" Property="Tipo">
                                <Template Context="falta">
                                    <span style="color: @(falta.Tipo == "Justificada" ? "green" : "red")">
                                        @falta.Tipo
                                    </span>
                                </Template>
                            </RadzenGridColumn>
                            <RadzenGridColumn TItem="FaltaDisplay" Title="Duração (min)" Property="Duracao" />
                        </Columns>
                    </RadzenGrid>
                </div>
            </div>
            @*FIM*@

            <div class="row" style="margin-top:1em;">
                <div class="col-md-12">
                    <h3>Histórico do Formando</h3>
                    <RadzenGrid AllowFiltering="true" AllowPaging="true" AllowSorting="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                    Data="@historicoFormando" TItem="EstadosFormando" ColumnWidth="200px">
                        <Columns>
                            <RadzenGridColumn TItem="EstadosFormando" Property="Estado.Nome" Title="Estado" />
                            <RadzenGridColumn TItem="EstadosFormando" Property="Data" Title="Data">
                                <Template Context="EstadosFormando">
                                    @String.Format("{0:d}", EstadosFormando.Data)
                                </Template>
                            </RadzenGridColumn>
                            <RadzenGridColumn TItem="EstadosFormando" Property="Observacoes" Title="Observações" />
                        </Columns>
                    </RadzenGrid>
                </div>
            </div>
        </RadzenCard>
    </Authorized>
</AuthorizeView>

<AuthorizeView Roles="Formador, Coordenador">
    <Authorized>
        <RadzenCard Style="margin-bottom: 60px;">
            <div class="row">
                <div class="col-md-6">
                    <div style="margin-top:20px">Email:</div>
                    <b>@formando.Email</b>
                    <div style="margin-top:20px">Contacto Telemóvel:</div>
                    <b>@formando.ContactoTelemovel</b>
                </div>
                <div class="col-md-6">
                    <img src="@foto" width="100" alt="" style="margin-top:1em;" />
                    <br />
                    @if (formando.CV != null)
                    {
                        <RadzenButton Click="VisualizarCV" Text="Visualizar o currículo" Style="margin-top:1em;" />
                    }
                </div>
            </div>
        </RadzenCard>
    </Authorized>
</AuthorizeView>


@code {
    [Parameter]
    public int FormandoId { get; set; }

    Formando formando = new Formando();
    List<EstadosFormando> historicoFormando = new List<EstadosFormando>();
    string foto, cnaef, habilitacoesLiterarias, nacionalidade;

    List<Formando> formandos, formandosComFaltas;
    List<Modulo> modulos;

    Formando formandoNota = new Formando();

    string email;

    // INICIO #008
    // Codigo para a tabela de Faltas

    private List<Falta> faltasDoFormando = new List<Falta>();

    // Helper method to format the grid data
    private List<FaltaDisplay> GetFaltasList()
    {
        return faltasDoFormando.Select(f => new FaltaDisplay
            {
                Data = f.HoraInicio.Date,
                Tipo = f.Justificada ? "Justificada" : "Injustificada",
                Duracao = f.Duracao,
                IsJustified = f.Justificada  // Add this property
            }).ToList();
    }

    // Display model
    public class FaltaDisplay
    {
        public DateTime Data { get; set; }
        public string Tipo { get; set; }
        public int Duracao { get; set; }
        public bool IsJustified { get; set; }  // New property
    }

    // Metodo para fazer download do CV
    void DownloadCv()
    {

    }
    // FIM

    protected async override void OnInitialized()
    {
        // INICIO #008
        // Faltas do formando
        faltasDoFormando = FaltaData.GetByFormandoId(FormandoId);
        // FIM

        formando = FormandoData.GetById(FormandoId);
        historicoFormando = FormandoData.ObterHistoricoDoFormando(FormandoId);

        string mail = formando.Email;
        email = $"mailto:{mail}";

        if (formando.Turma != null)
        {
            modulos = moduloData.GetModulosComFormadorByTurma(formando.Turma.Id);
            modulos.OrderBy(m => m.Id);

            formandos = FormandoData.GetAllByTurmaWithAvaliacao(formando.Turma.Id).Where(f => f.Id == FormandoId).ToList();

            formandosComFaltas = FormandoData.GetAllByTurmaComFaltas(formando.Turma.Id).Where(f => f.Id == FormandoId).ToList();

            //atribui as faltas (da lista formandosComFaltas) à lista de formandos
            if (formandosComFaltas.Count() != 0)
            {
                formandos.First().FaltaJustificadas = formandosComFaltas.First().FaltaJustificadas;
                formandos.First().FaltaInjustificadas = formandosComFaltas.First().FaltaInjustificadas;
                formandos.First().Turma.Curso = formandosComFaltas.First().Turma.Curso;
            }
        }

        if (formando.CodigoCNAEF != null)
        {
            cnaef = CNAEFData.GetById(Convert.ToInt32(formando.CodigoCNAEF)).AreaFormacao;
        }
        if (formando.HabilitacoesLiterarias != 0)
        {
            habilitacoesLiterarias = HabilitacoesData.GetById(formando.HabilitacoesLiterarias).HabilitacoesLiterarias;
        }
        if (formando.Nacionalidade != null)
        {
            nacionalidade = PaisesData.GetById(formando.Nacionalidade).nome;
        }
        if (formando.Foto != null)
        {
            foto = FileMngSrv.PathToBase64String(formando.Foto);
        }
    }

    public async void VisualizarCV()
    {
        await JSRuntime.InvokeAsync<object>("open", new CancellationToken(), $"CV/{formando.Id}", "_blank");
    }
}
