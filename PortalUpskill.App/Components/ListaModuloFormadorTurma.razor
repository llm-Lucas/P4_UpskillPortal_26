@page "/ModulosFormadorTurma/{Idf:int}/{Id:int}"

@inject IModuloData moduloData
@inject ITurmaData turmaData

<h1>@Title @getTurmaAtual()</h1>

<RadzenGrid Data="@modulos"
TItem="Modulo"
AllowSorting="true"
AllowFiltering="true"
FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
AllowPaging="true"
PageSize="10">
    <Columns>
        <RadzenGridColumn TItem="Modulo" Property="Nome" Title="Nome" />
        <RadzenGridColumn TItem="Modulo" Property="Horas" Title="Duração em Horas" />
        <!--INICIO #008-->
        <!--Coluna para dizer se o Modulo ja teve inicio-->
        <RadzenGridColumn TItem="Modulo" Property="" Title="Modulo Iniciado" />

        <!--Coluna para dizer se o Modulo ja foi concluido-->
        <RadzenGridColumn TItem="Modulo" Property="" Title="Modulo Concluido" />

        <!--Coluna para ver detalhes do modulo-->
        <RadzenGridColumn Title="Opções" TItem="Modulo" Sortable="false" Filterable="false">
            <Template Context="Modulo">
                <RadzenButton Title="Ver detalhes" Size="ButtonSize.Medium" Icon="description" Click=@(args => dialogService.Open<DetalhesModulo>($"Detalhes",
                                                                                    new Dictionary<string, object>() { { "ModuloId", Modulo.Id } },
                                                                                    new DialogOptions(){ Width = "80%", Height = "90%" })) />
            </Template>
        </RadzenGridColumn>
        <!--FIM-->
    </Columns>
</RadzenGrid>

<!-- INÍCIO #008 -->
<div class="row justify-content-center">
    <div class="col-md-12 d-flex align-items-end justify-content-center" style="margin-top: 16px;">
        <!-- <RadzenButton ButtonType="ButtonType.Submit" ButtonStyle="ButtonStyle.Success" Icon="save" Text="Guardar" Click="@(() => MarcarFaltas())" /> -->
        <AuthorizeView Roles="Administrador, Secretariado">
            <Authorized>
                <RadzenButton ButtonStyle="ButtonStyle.Secondary" Icon="cancel" style="display: inline-block; margin-left: 10px;" Text="Voltar" Click="@(() => navManager.NavigateTo($"Calendar/{aulaVM.TurmaId}"))" />
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Roles="Formador">
            <Authorized>
                <RadzenButton ButtonStyle="ButtonStyle.Secondary" Icon="cancel" style="display: inline-block; margin-left: 10px;" Text="Voltar" Click="@(() => navManager.NavigateTo($"TurmasPorFormador"))" />
            </Authorized>
        </AuthorizeView>
    </div>
</div>
<!-- FIM -->

@code {

    // INÍCIO #008
    // Instancia a ViewModel para a Aula
    // É necessário para o botão de Voltar
    AulaViewModel aulaVM = new AulaViewModel();

    // Receber a Turma Atual que foi carregada
    string turmaAtual = "";

    // Metodo para ir buscar a turma selecionada e guardar na string turmaAtual
    public string getTurmaAtual()
    {
        var turma = turmaData.GetById(Id);
        if (turma != null)
        {
            turmaAtual = turma.Nome;
        }

		return turmaAtual;
    }

    // FIM

    List<Modulo> modulos;

    [Parameter]
    public string Title { get; set; } = "Módulos da Turma ";

    [Parameter]
    public int Idf { get; set; } //id formador
    [Parameter]
    public int Id { get; set; } // id do turma

    protected override async Task OnInitializedAsync()
    {
        LoadModulos();
    }

    void LoadModulos()
    {
        modulos = moduloData.GetByIdFormadorIdTurma(Idf,Id);
    }

}