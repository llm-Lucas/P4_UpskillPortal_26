@page "/Detalhes/Turma/{TurmaId:int}"

@inject IFormandoData FormandoData
@inject ITurmaData TurmaData
@inject IModuloData ModuloData
@inject FileManagerService FileMngSrv
@inject IJSRuntime JSRuntime

<div class="cardstyle">
    <h2>@turma.Nome</h2>
    <br />
    <div class="row">
        <div class="col-md-12">
            <p><b>Curso:</b> @turma.Curso.Nome</p>
            <p><b>Data de Início:</b> @String.Format("{0:d}", turma.DataInicioCurso)</p>
            <p><b>Data de Fim:</b> @String.Format("{0:d}", turma.DataFimCurso)</p>
            <p><b>Módulos:</b></p>
            <ul>
                @foreach (Modulo modulo in modulos)
                {
                    string sigla = $"M{@modulo.Id}";
                    <li><b>@sigla</b> - @modulo.Nome - @modulo.Formador.Nome</li>
                }
            </ul>
            <AuthorizeView Roles="Administrador, Secretariado">
                <Authorized>
                    <RadzenButton Size="ButtonSize.Medium" ButtonStyle="ButtonStyle.Primary" Icon="edit_calendar" Title="Calendarizar Aulas" Click="@(() => navManager.NavigateTo($"Calendar/{turma.Id}"))" />
                    <RadzenButton Size="ButtonSize.Medium" ButtonStyle="ButtonStyle.Primary" Icon="grading" Title="Download das Pautas de Avaliação" Click="@(() => navManager.NavigateTo($"TurmaAvaliacoes/{turma.Id}"))" />
                    <RadzenButton Text="Excel" Icon="grid_on" Click="@(args => Exportar(".xlsx"))" Style="margin-bottom:20px" />
                    <RadzenButton Text="Enviar Email" Icon="email" ButtonStyle="ButtonStyle.Success"
                                  Disabled="@(!selectedFormandos.Any())"
                                  Click="@(() => navManager.NavigateTo(BuildMailToLink(), true))" />
                </Authorized>
            </AuthorizeView>
            <AuthorizeView Roles="Formador, Coordenador">
                <Authorized>
                    <RadzenButton Size="ButtonSize.Medium" ButtonStyle="ButtonStyle.Primary" Icon="today" Title="Ver Aulas" Click="@(() => navManager.NavigateTo($"/Sumarios/{turma.Id}?from=detalhes&turmaId={turma.Id}"))" />
                </Authorized>
            </AuthorizeView>
        </div>
    </div>
</div>
<div class="cardstyle">
    <div class="row" style="margin-top:1em;">
        <div class="col-md-12">
            <h3>Formandos</h3>
            <RadzenGrid Data="@formandos"
                        TItem="Formando"
                        AllowSorting="true"
                        AllowFiltering="true"
                        FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                        AllowPaging="true"
                        PageSize="10">
                <Columns>
                    <RadzenGridColumn TItem="Formando" Title="Selecionar" Sortable="false" Filterable="false" Width="50px">
                        <HeaderTemplate>
                            <RadzenCheckBox TValue="bool"
                                            Value="@selectAll"
                                            ValueChanged="@((bool value) => ToggleSelectAll(value))"
                                            Change="@((args) => {})" />
                        </HeaderTemplate>
                        <Template Context="formando">
                            <RadzenCheckBox TValue="bool"
                                            Value="@IsSelected(formando.Id)"
                                            ValueChanged="@((bool checkedValue) => ToggleSelection(formando.Id, checkedValue))"
                                            Change="@((args) => {})" />
                        </Template>
                    </RadzenGridColumn>
                    <RadzenGridColumn TItem="Formando" Property="Nome" Title="Nome" />
                    <RadzenGridColumn TItem="Formando" Title="FJ*" Sortable="false">
                        <Template Context="Formando">
                            @if (Formando.FaltaJustificadas != null)
                            {
                                <span>@((Formando.FaltaJustificadas.Duracao / 60.0 / Formando.Turma.Curso.DuracaoHoras * 100).ToString("0.##"))%</span>
                            }
                            else
                            {
                                <span>0%</span>
                            }
                        </Template>
                        <FooterTemplate>
                            <i>*Faltas Justificadas</i>
                        </FooterTemplate>
                    </RadzenGridColumn>
                    <RadzenGridColumn TItem="Formando" Title="FI*" Sortable="false">
                        <Template Context="Formando">
                            @if (Formando.FaltaInjustificadas != null)
                            {
                                <span>@((Formando.FaltaInjustificadas.Duracao / 60.0 / Formando.Turma.Curso.DuracaoHoras * 100).ToString("0.##"))%</span>
                            }
                            else
                            {
                                <span>0%</span>
                            }
                        </Template>
                        <FooterTemplate>
                            <i>*Faltas Injustificadas</i>
                        </FooterTemplate>
                    </RadzenGridColumn>

                    @for (int i = 0; i < modulos.Count(); i++)
                    {
                        int index = i;
                        string title = $"Média M{modulos[index].Id}";

                        <RadzenGridColumn TItem="Formando" Property="" Title="@title" Sortable="false">
                            <Template Context="Formando">
                                @if (Formando.DictAvaliacaoModular.Count() != 0)
                                {
                                    @if (Formando.DictAvaliacaoModular.ContainsKey(modulos[index].Id) && Formando.DictAvaliacaoModular[modulos[index].Id].NotaFinal >= 10)
                                    {
                                        <span style='color:green'>@(Formando.DictAvaliacaoModular[modulos[index].Id].NotaFinal.ToString("0.##"))</span>
                                    }
                                    else if (Formando.DictAvaliacaoModular.ContainsKey(modulos[index].Id) && Formando.DictAvaliacaoModular[modulos[index].Id].NotaFinal < 10)
                                    {
                                        <span style='color:red'>@(Formando.DictAvaliacaoModular[modulos[index].Id].NotaFinal.ToString("0.##")) </span>
                                    }
                                    else
                                    {
                                        <span>Sem nota</span>
                                    }
                                }
                                else
                                {
                                    <span>Sem nota</span>
                                }
                            </Template>
                        </RadzenGridColumn>
                    }

                    <RadzenGridColumn TItem="Formando" Property="" Title="Nota Final" Sortable="false">
                        <Template Context="Formando">
                            @if (Formando.AvaliacaoFinal != null && Formando.AvaliacaoFinal.NotaFinal >= 10)
                            {
                                <span style='color:darkgreen'>@(Formando.AvaliacaoFinal.NotaFinal.ToString("0.##"))</span>
                            }
                            else if (Formando.AvaliacaoFinal != null && Formando.AvaliacaoFinal.NotaFinal < 10)
                            {
                                <span style='color:red'>@(Formando.AvaliacaoFinal.NotaFinal.ToString("0.##"))</span>
                            }
                            else
                            {
                                <span>Sem nota</span>
                            }
                        </Template>
                    </RadzenGridColumn>
                    <RadzenGridColumn TItem="Formando" Title="Detalhes" Sortable="false" Filterable="false">
                        <Template Context="Formando">
                            <RadzenButton Title="Ver detalhes" Size="ButtonSize.Medium" Icon="description" Click=@(args => dialogService.Open<DetalhesFormando>($"Detalhes",
                                                                                                                             new Dictionary<string, object>() { { "FormandoId", Formando.Id } },
                                                                                                                             new DialogOptions() { Width = "80%", Height = "90%" })) />
                        </Template>
                    </RadzenGridColumn>
                </Columns>
            </RadzenGrid>
        </div>
    </div>
</div>

<!-- INÍCIO #008 -->
<div class="row justify-content-center">
    <div class="col-md-12 d-flex align-items-end justify-content-center" style="margin-top: 16px;">
        <AuthorizeView Roles="Administrador, Secretariado, Coordenador">
            <Authorized>
                <RadzenButton ButtonStyle="ButtonStyle.Secondary" Icon="cancel" style="display: inline-block; margin-left: 10px;" Text="Voltar" Click="@(() => navManager.NavigateTo($"Turmas"))" />
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Roles="Formador">
            <Authorized>
                <RadzenButton ButtonStyle="ButtonStyle.Secondary" Icon="cancel" style="display: inline-block; margin-left: 10px;" Text="Voltar" Click="@(() => navManager.NavigateTo($"AvaliacaoPorFormador"))" />
            </Authorized>
        </AuthorizeView>
    </div>
</div>
<!-- FIM -->
<br />

@code {
    [Parameter]
    public int TurmaId { get; set; }

    List<Formando> formandos, formandosComFaltas;
    List<Formando> formandosComNotaFinalUpdate = new List<Formando>(), formandosComNotaFinalCreate = new List<Formando>();
    Turma turma;
    List<Modulo> modulos;

    string email;
    string mail;

    AulaViewModel aulaVM = new AulaViewModel();

    HashSet<int> selectedFormandos = new();
    bool selectAll = false;

    bool IsSelected(int id) => selectedFormandos.Contains(id);

    void ToggleSelection(int id, bool isSelected)
    {
        if (isSelected)
        {
            selectedFormandos.Add(id);
        }
        else
        {
            selectedFormandos.Remove(id);
            selectAll = false;
        }
    }

    void ToggleSelectAll(bool isSelected)
    {
        selectAll = isSelected;

        if (isSelected)
        {
            selectedFormandos = formandos.Select(f => f.Id).ToHashSet();
        }
        else
        {
            selectedFormandos.Clear();
        }
    }

    string BuildMailToLink()
    {
        if (!selectedFormandos.Any()) return "#";

        var selectedEmails = formandos
            .Where(f => selectedFormandos.Contains(f.Id))
            .Select(f => f.Email)
            .Where(email => !string.IsNullOrWhiteSpace(email))
            .Distinct();

        var mailto = "mailto:" + string.Join(",", selectedEmails);
        return mailto;
    }

    bool value;

    protected override async Task OnInitializedAsync()
    {
        formandos = FormandoData.GetAllByTurmaWithAvaliacao(TurmaId);
        formandosComFaltas = FormandoData.GetAllByTurmaComFaltas(TurmaId);
        turma = TurmaData.GetById(TurmaId);
        modulos = ModuloData.GetModulosComFormadorByTurma(TurmaId);
        modulos.OrderBy(m => m.Id);

        foreach (var formando in formandosComFaltas)
        {
            var targetFormando = formandos.Single(f => f.Id == formando.Id);
            targetFormando.FaltaJustificadas = formando.FaltaJustificadas;
            targetFormando.FaltaInjustificadas = formando.FaltaInjustificadas;
            targetFormando.Turma.Curso = formando.Turma.Curso;
        }

        foreach (var formando in formandos)
        {
            if (formando.DictAvaliacaoModular.Count() == modulos.Count())
            {
                if (formando.AvaliacaoFinal != null && formando.AvaliacaoFinal.NotaFinal != 0)
                {
                    double notaFinal = 0;
                    foreach (var modulo in modulos)
                    {
                        notaFinal += formando.DictAvaliacaoModular[modulo.Id].NotaFinal;
                    }
                    if (formando.AvaliacaoFinal.NotaFinal != notaFinal / modulos.Count())
                    {
                        formando.AvaliacaoFinal.NotaFinal = notaFinal / modulos.Count();
                        formandosComNotaFinalUpdate.Add(formando);
                    }
                }
                else
                {
                    double notaFinal = 0;
                    foreach (var modulo in modulos)
                    {
                        notaFinal += formando.DictAvaliacaoModular[modulo.Id].NotaFinal;
                    }
                    formando.AvaliacaoFinal = new AvaliacaoFinal();
                    formando.AvaliacaoFinal.NotaFinal = notaFinal / modulos.Count();
                    formandosComNotaFinalCreate.Add(formando);
                }
            }
        }

        FormandoData.CreateAvaliacaoFinal(formandosComNotaFinalCreate);
        FormandoData.UpdateAvaliacaoFinal(formandosComNotaFinalUpdate);

        foreach (var formando in formandos)
        {
            mail = mail + formando.Email + ";";
        }

        email = $"mailto:{mail}";
    }

    async void Exportar(string extension)
    {
        IXLWorkbook workbook = new XLWorkbook();
        IXLWorksheet worksheet = workbook.Worksheets.Add("turmas");

        #region Template Topo
        var currentRow = 1;
        var currentColumn = 1;

        worksheet.AddPicture("wwwroot/img/pauta/iefp.png")
                 .MoveTo(worksheet.Cell(currentRow, currentColumn));
        currentColumn += 3;
        worksheet.AddPicture("wwwroot/img/pauta/iscte.png")
                 .MoveTo(worksheet.Cell(currentRow, currentColumn))
                 .Scale(.07);
        currentColumn += 3;
        worksheet.AddPicture("wwwroot/img/pauta/upskill.png")
             .MoveTo(worksheet.Cell(currentRow, currentColumn));

        currentRow += 5;
        currentColumn -= 6;
        #endregion

        #region Cabeçalho
        var rngCabeçalhoFirstColumn = currentColumn;

        worksheet.Cell(currentRow, currentColumn++).Value = "Turma";
        worksheet.Cell(currentRow, currentColumn++).Value = "Curso";
        worksheet.Cell(currentRow, currentColumn++).Value = "Data de início";
        worksheet.Cell(currentRow, currentColumn++).Value = "Data de fim";
        worksheet.Cell(currentRow, currentColumn).Value = "Horário";

        var rngCabeçalho = worksheet.Range(currentRow, rngCabeçalhoFirstColumn, currentRow, currentColumn);
        rngCabeçalho.Columns().Style.Border.OutsideBorder = XLBorderStyleValues.Thin;
        rngCabeçalho.Style.Font.FontName = "Century Gothic";
        rngCabeçalho.Style.Font.FontSize = 15;
        rngCabeçalho.Style.Font.Bold = true;
        rngCabeçalho.Style.Fill.BackgroundColor = XLColor.FromArgb(204, 255, 255);

        currentColumn = rngCabeçalhoFirstColumn;
        #endregion

        #region Corpo
        var rngCorpo = worksheet.Range(1, 1, 1, 1);
        var rngCorpoFirstRow = currentRow;
        var rngCorpoFirstColumn = currentColumn;

        currentRow++;

        worksheet.Cell(currentRow, currentColumn++).Value = turma.Nome;
        worksheet.Cell(currentRow, currentColumn).Style.Font.Bold = true;

        worksheet.Cell(currentRow, currentColumn++).Value = turma.Curso.Nome;
        worksheet.Cell(currentRow, currentColumn++).Value = turma.DataInicioCurso;
        worksheet.Cell(currentRow, currentColumn++).Value = turma.DataFimCurso;

        DateTime ManhaInicio = Convert.ToDateTime(turma.HorarioAssincronoInicio);
        DateTime ManhaFim = Convert.ToDateTime(turma.HorarioAssincronoFim);
        DateTime TardeInicio = Convert.ToDateTime(turma.HorarioSincronoInicio);
        DateTime TardeFim = Convert.ToDateTime(turma.HorarioSincronoFim);
        worksheet.Cell(currentRow, currentColumn).Value = ManhaInicio.ToString("HH : mm") + " - " + ManhaFim.ToString("HH : mm") + " | " + TardeInicio.ToString("HH : mm") + " - " + TardeFim.ToString("HH : mm");

        rngCorpo = worksheet.Range(rngCorpoFirstRow, rngCorpoFirstColumn, currentRow, currentColumn);

        currentColumn = rngCorpoFirstColumn;

        rngCorpo.Columns().Style.Border.OutsideBorder = XLBorderStyleValues.Thin;
        rngCorpo.Cells().Style.Alignment.SetHorizontal(XLAlignmentHorizontalValues.Left);
        worksheet.Columns().AdjustToContents();
        #endregion

        #region Cabeçalho formandos
        rngCabeçalhoFirstColumn = currentColumn;
        currentRow += 2;

        worksheet.Cell(currentRow, currentColumn++).Value = "Formando";
        worksheet.Cell(currentRow, currentColumn++).Value = "Total Faltas Justificadas";
        worksheet.Cell(currentRow, currentColumn++).Value = "%";
        worksheet.Cell(currentRow, currentColumn++).Value = "Total Faltas Injustificadas";
        worksheet.Cell(currentRow, currentColumn++).Value = "%";
        foreach (var modulo in modulos)
        {
            string sigla = $"M{modulo.Id}";
            worksheet.Cell(currentRow, currentColumn++).Value = "Média " + sigla;
        }
        worksheet.Cell(currentRow, currentColumn).Value = "Nota Final";

        rngCorpo = worksheet.Range(rngCorpoFirstRow, rngCabeçalhoFirstColumn, currentRow, currentColumn);

        rngCabeçalho = worksheet.Range(currentRow, rngCabeçalhoFirstColumn, currentRow, currentColumn);
        rngCabeçalho.Columns().Style.Border.OutsideBorder = XLBorderStyleValues.Thin;
        rngCabeçalho.Style.Font.FontName = "Century Gothic";
        rngCabeçalho.Style.Font.FontSize = 15;
        rngCabeçalho.Style.Font.Bold = true;
        rngCabeçalho.Style.Fill.BackgroundColor = XLColor.FromArgb(204, 255, 255);

        currentColumn = rngCabeçalhoFirstColumn;
        #endregion

        #region Corpo formandos
        rngCorpo = worksheet.Range(1, 1, 1, 1);
        rngCorpoFirstRow = currentRow;
        rngCorpoFirstColumn = currentColumn;

        foreach (var formando in formandos)
        {
            currentColumn = rngCorpoFirstColumn;
            currentRow++;

            worksheet.Cell(currentRow, currentColumn++).Value = formando.Nome;
            if (formando.FaltaJustificadas != null)
            {
                worksheet.Cell(currentRow, currentColumn++).Value = formando.FaltaJustificadas.Duracao / 60;
                worksheet.Cell(currentRow, currentColumn++).Value = (formando.FaltaJustificadas.Duracao / 60 / formando.Turma.Curso.DuracaoHoras * 100).ToString("0.##");
            }
            else
            {
                worksheet.Cell(currentRow, currentColumn++).Value = 0;
                worksheet.Cell(currentRow, currentColumn++).Value = 0;
            }
            if (formando.FaltaInjustificadas != null)
            {
                worksheet.Cell(currentRow, currentColumn++).Value = formando.FaltaInjustificadas.Duracao / 60;
                worksheet.Cell(currentRow, currentColumn++).Value = (formando.FaltaInjustificadas.Duracao / 60 / formando.Turma.Curso.DuracaoHoras * 100).ToString("0.##");
            }
            else
            {
                worksheet.Cell(currentRow, currentColumn++).Value = 0;
                worksheet.Cell(currentRow, currentColumn++).Value = 0;
            }

            for (int i = 0; i < modulos.Count(); i++)
            {
                worksheet.Cell(currentRow, currentColumn++).Value = formando.DictAvaliacaoModular[modulos[i].Id].NotaFinal;
            }

            worksheet.Cell(currentRow, currentColumn).Value = formando.AvaliacaoFinal.NotaFinal;
        }

        rngCorpo.Columns().Style.Border.OutsideBorder = XLBorderStyleValues.Thin;
        rngCorpo.Cells().Style.Alignment.SetHorizontal(XLAlignmentHorizontalValues.Left);
        worksheet.Columns().AdjustToContents();
        #endregion

        #region Template rodapé
        currentRow += 3;
        worksheet.AddPicture("wwwroot/img/pauta/gov.jpg")
                 .MoveTo(worksheet.Cell(currentRow + 3, 4))
                 .Scale(.74);
        #endregion

        var timestamp = Convert.ToString(DateTime.Now);

        await FileMngSrv.DownloadWorkbook(workbook, extension, timestamp + "_" + turma.Nome);
    }
}