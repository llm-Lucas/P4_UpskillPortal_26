                    </FilterTemplate>
                    <!-- FIM -->
                    <Template Context="Formando">
                        @if (Formando.Turma != null)
                        {
                            @Formando.Turma.Nome
                        }
                    </Template>
                </RadzenGridColumn>

                <RadzenGridColumn TItem="Formando" Property="Turma.Curso.Nome" Title="Curso">
                    <!-- INICIO #008 -->
                    <!-- Filtragem por Curso -->
                    <FilterTemplate>
                        <RadzenDropDown @bind-Value="@filtroCurso" TextProperty="Nome" ValueProperty="Id" Style="width:100%"
                        Change="@(_ => ApplyFilters())"
                        Data="@cursos.Select(c => c.Nome)" />
                    </FilterTemplate>
                    <!-- FIM -->
                    <Template Context="Formando">
                        @if (Formando.Turma != null)
                        {
