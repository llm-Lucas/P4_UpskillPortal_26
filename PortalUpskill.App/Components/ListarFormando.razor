                            {
                                //introduzir logica para mostrar o curso
                                //@Formando.Curso
                            }
                        </Template>
                    </RadzenGridColumn>
                }
                else
                {
                    <RadzenGridColumn TItem="Formando" Title="Intenção curso">
                        <!--Property="IntencaoCurso"-->
                        <Template Context="Formando">
                            @if (Formando.Turma != null)
                            {
