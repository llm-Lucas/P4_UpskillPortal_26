                                @Formando.Turma
                            }
                        </Template>
                    </RadzenGridColumn>
                }
                <!--FIM #004-->
            }
            else
            {
                <RadzenGridColumn TItem="Formando" Property="Turma.Nome" Title="Turma">
                    <!-- INICIO #008 -->
                    <!-- Filtragem por Turma -->
