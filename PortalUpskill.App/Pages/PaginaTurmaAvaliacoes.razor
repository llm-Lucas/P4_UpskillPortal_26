	public class AvaliacaoLinha
	{
		public int FormandoId { get; set; }
		public string Nome { get; set; }
		public double NotaFinal { get; set; }
		public string Comentarios { get; set; }
	}
	void GuardarAvaliacaoLinha(Syncfusion.Blazor.Grids.ActionEventArgs<AvaliacaoLinha> args)
	{
		if (args.RequestType == Syncfusion.Blazor.Grids.Action.Save)
		{
			AvaliacaoLinha linha = (AvaliacaoLinha)args.Data;

			Formando formando = formandos.FirstOrDefault(f => f.Id == linha.FormandoId);

			if (formando != null)
			{
				if (!formando.DictAvaliacaoModular.ContainsKey(selectedModuloId))
				{
					formando.DictAvaliacaoModular.Add(selectedModuloId, new AvaliacaoModular());
				}

				formando.DictAvaliacaoModular[selectedModuloId].NotaFinal = linha.NotaFinal;
				formando.DictAvaliacaoModular[selectedModuloId].Comentarios = linha.Comentarios;

				GravarAvaliacaoNaBD(linha);
			}
		}
	}
	void GravarAvaliacaoNaBD(AvaliacaoLinha linha)
	{
		Formando formando = formandos.FirstOrDefault(f => f.Id == linha.FormandoId);

		if (formando == null)
		{
			return;
		}

		if (!formando.DictAvaliacaoModular.ContainsKey(selectedModuloId))
		{
			formando.DictAvaliacaoModular.Add(selectedModuloId, new AvaliacaoModular());
		}

		formando.DictAvaliacaoModular[selectedModuloId].NotaFinal = linha.NotaFinal;
		formando.DictAvaliacaoModular[selectedModuloId].Comentarios = linha.Comentarios;

		List<Formando> lista = new List<Formando>();
		lista.Add(formando);

		if (formandosNotaEstadoInicial.Single(f => f.Id == formando.Id).DictAvaliacaoModular.ContainsKey(selectedModuloId))
		{
			formandoData.UpdateAvaliacaoModular(lista, selectedModuloId);
		}
		else
		{
			formandoData.CreateAvaliacaoModular(lista, selectedModuloId, formadorId);
		}

		notificationService.Notify(new NotificationMessage
		{
			Severity = NotificationSeverity.Success,
			Summary = "Avaliação gravada com sucesso.",
			Duration = 3000
		});
	}
	
