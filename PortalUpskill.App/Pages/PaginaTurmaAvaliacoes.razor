	}

	List<Modulo> modulos;
	List<Formando> formandos = new List<Formando>();
	List<AvaliacaoLinha> avaliacoesLinhas = new List<AvaliacaoLinha>();
	List<Formando> formandosNotaEstadoInicial;
	List<Formando> formandosNotasUpdate;
	List<Formando> formandosNotasCreate;
	Turma turma;

	[CascadingParameter]
	Task<AuthenticationState> authStateTask { get; set; }

	int selectedModuloId;
	int selectedCursoId;
	int formadorId;
