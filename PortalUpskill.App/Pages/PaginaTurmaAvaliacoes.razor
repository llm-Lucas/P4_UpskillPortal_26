	// FIM

	protected override async Task OnInitializedAsync()
	{
		string user = (await authStateTask).User.Identity.Name;
		Pessoa pessoa = new Pessoa();
		pessoa = pessoaData.GetByEmail(user);

		if (pessoa.Perfil.Id == 3)
		{
			modulos = moduloData.GetModulosComFormadorByTurma(TurmaId).Where(m => m.Formador.Id == pessoa.Id).ToList();
		}
		else
		{
			modulos = moduloData.GetModulosComFormadorByTurma(TurmaId);
		}
		formandos = formandoData.GetAllByTurmaWithAvaliacao(TurmaId);
		turma = turmaData.GetById(TurmaId);
		selectedCursoId = (int)turma.CursoId;
	}
	void CarregarAvaliacoesLinhas()
	{
		avaliacoesLinhas.Clear();

		foreach (var formando in formandos)
		{
			AvaliacaoLinha linha = new AvaliacaoLinha();

			linha.FormandoId = formando.Id;
			linha.Nome = formando.Nome;

			if (formando.DictAvaliacaoModular.ContainsKey(selectedModuloId))
			{
				linha.NotaFinal = formando.DictAvaliacaoModular[selectedModuloId].NotaFinal;
				linha.Comentarios = formando.DictAvaliacaoModular[selectedModuloId].Comentarios;
			}
			else
			{
				linha.NotaFinal = 0;
				linha.Comentarios = "";
			}

			avaliacoesLinhas.Add(linha);
		}
	}
	async Task OnModuloSelected()
	{
		//cria uma cópia dos formandos para gravar as notas iniciais para comparar mais tarde
		formandosNotaEstadoInicial = new List<Formando>(formandos.Count);
		formandos.ForEach(f => formandosNotaEstadoInicial.Add(new Formando(f)));
		if (modulos.Count() != 0 && selectedModuloId != 0)
		{
			formadorId = modulos.Single(m => m.Id == selectedModuloId).Formador.Id;
		}
		fileMsg1 = ""; fileMsg2 = "";
		if (FMS.FileExists(turma.Nome, selectedModuloId))
		{
			fileMsg1 = $"pauta_turma_{turma.Nome}_M{ selectedModuloId}.xlsm";
			fileMsg2 = "Já existe uma pauta registada, caso queira atualizar selecione a nova pauta";
		}
		CalcularEditarStatus();
		CarregarAvaliacoesLinhas();
	}

	IBrowserFile selectedExcel;
	string msg = "", path;

	async void OnInputExcel(InputFileChangeEventArgs e)
	{
		selectedExcel = e.File;
		this.StateHasChanged();

		//guarda o path do ficheiro
		path = FMS.ExcelPath(selectedExcel, turma.Nome, selectedModuloId);
		if (path != "")
		{
			msg = "";
			//cria o ficheiro no path anterior
			await FMS.UploadFile(selectedExcel, path);
			ImportExcel();

			formandosNotasUpdate = new List<Formando>();
			formandosNotasCreate = new List<Formando>();
			foreach (var formando in formandos)
			{
				if (formando.DictAvaliacaoModular.Count != 0)
				{
					//verifica se existe alguma nota no estado inicial
					if (formandosNotaEstadoInicial.Single(f => f.Id == formando.Id).DictAvaliacaoModular.ContainsKey(selectedModuloId))
					{
						//verifica se a nota é diferente do estado inicial => UPDATE (se for igual não acontece nada)
						if (formando.DictAvaliacaoModular[selectedModuloId].NotaFinal != formandosNotaEstadoInicial.Single(f => f.Id == formando.Id).DictAvaliacaoModular[selectedModuloId].NotaFinal)
						{
							formandosNotasUpdate.Add(formando);
						}
					}
					//verifica se existe uma nota nova => CREATE
					else if (formando.DictAvaliacaoModular.ContainsKey(selectedModuloId) && formando.DictAvaliacaoModular[selectedModuloId].NotaFinal != 0)
					{
						formandosNotasCreate.Add(formando);
					}
				}
			}

			//cria ou faz update as notas dos formandos na bd
			if (formandosNotasCreate.Count() > 0)
				formandoData.CreateAvaliacaoModular(formandosNotasCreate, selectedModuloId, formadorId);
			if (formandosNotasUpdate.Count() > 0)
				formandoData.UpdateAvaliacaoModular(formandosNotasUpdate, selectedModuloId);

			if (formandosNotasCreate.Count() > 0 || formandosNotasUpdate.Count() > 0)
				notificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Operação efetuada com sucesso!", Duration = 4000 });
			else
				notificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Warning, Summary = "Ou as notas já estão em sistema ou o ficheiro está vazio.", Duration = 4000 });

			//faz load aos formandos
			formandos = formandoData.GetAllByTurmaWithAvaliacao(TurmaId);
			fileMsg1 = $"pauta_turma_{turma.Nome}_M{selectedModuloId}.xlsm";
			StateHasChanged();
		}
		else
		{
			//aparece a seguinte mensagem se o ficheiro for diferente de uma das extensoes de baixo
			msg = "O ficheiro que seleccionou não é do tipo .xlsx/.xls/.xlsm";
		}
	}

	public void ImportExcel()
	{
		if (path != "")
		{
			//Started reading the Excel path.
			using (XLWorkbook workbook = new XLWorkbook(path))
			{
				IXLWorksheet worksheet = workbook.Worksheet(1);

				//começa a ler o ficheiro na linha 9
				var currentRow = worksheet.Row(9);
				while (!currentRow.Cell(2).IsEmpty())
				{
					//vai buscar o nome à pauta de cada formando linha a linha
					string nome = currentRow.Cell(2).GetValue<string>();
					//faz o split do nome de cima
					string[] nomeSplit = nome.Split(' ');

					//faz a procura pelo nome da pauta na lista de formandos
					foreach (var formando in formandos)
					{
						bool nomeIgual = false;
						bool match = false;
						do
						{
							for (int i = 0; i < nomeSplit.Length; i++)
							{
								if (formando.Nome.Contains(nomeSplit[i]))
								{
									nomeIgual = true;
									if (i == (nomeSplit.Length - 1))
									{
										if (currentRow.Cell(23).CachedValue.ToString() != "")//!currentRow.Cell(23).IsEmpty()
										{
											formando.DictAvaliacaoModular.Remove(selectedModuloId);
											//guarda a nota final do modulo no dicionário para o respectivo formando
											formando.DictAvaliacaoModular.Add(selectedModuloId, new AvaliacaoModular() { NotaFinal = Convert.ToInt32(currentRow.Cell(23).CachedValue) });

											if (!currentRow.Cell(24).IsEmpty())
											{
												//guarda os comentários no dicionário
												formando.DictAvaliacaoModular[selectedModuloId].Comentarios = currentRow.Cell(24).GetValue<string>();
											}
										}
										nomeIgual = false;//serve para sair do while
										match = true;//o formando foi encontrado e serve para dar break ao foreach
									}
								}
								else
								{
									nomeIgual = false;
									break;
								}
							}
						} while (nomeIgual == true);

						//se o formando for encontrado faz break ao foreach
						if (match == true) break;
					}

					//passa para a linha seguinte
					currentRow = currentRow.RowBelow();
				}
			}
		}
	}

	async void DownloadAvaliacao()
	{
		string data = FMS.PathToBase64String(selectedModuloId, turma.Nome);
		if (data != "")
		{
			await JSRuntime.InvokeAsync<object>("saveAsFile", $"pauta_turma_{turma.Id}_M{selectedModuloId}.xlsm", data);
		}
		else
		{
			notificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Warning, Summary = "Não existe nenhum documento gravado em sistema!", Duration = 4000 });
		}
	}
