@attribute [Authorize(Roles = "Administrador, Secretariado")]
@page "/Calendar"
@page "/Calendar/{Id:int}"


@inject IWebHostEnvironment env
@inject ITurmaData turmaData
@inject ICursoData cursoData
@inject IAulaData aulaData
@inject IFaltaData faltaData
@inject IFormadorData formadorData
@inject IFormandoData formandoData
@inject IPessoaData pessoaData
@inject IModuloData moduloData
@inject ProtectedSessionStorage sessionStorage
@inject FileManagerService fileManager

@using Radzen

<div class="cardstyle">
	<div style="display: flex; gap: 1rem; align-items: flex-start;">
		<div style="flex:1">
	<h3>Selecione uma turma</h3>
	<RadzenDropDown class="w-75" Data="@turmas" @bind-Value="SelectedTurmaId" Change="OnTurmaSelected" TValue="int" ValueProperty="Id" TextProperty="Nome"
					AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
					AllowClear="false">
		<Template Context="Turma">
			<span>@Turma.Nome - @Turma.Curso.Nome</span>
		</Template>
	</RadzenDropDown>
		</div>
	
	</div>
	@if (SelectedTurma != null)
	{
		<div class="row">
			<span class="col-4"><b>Horário Assíncrono:</b> @SelectedTurma.HorarioAssincronoInicio.Value.ToString("HH:mm") - @SelectedTurma.HorarioAssincronoFim.Value.ToString("HH:mm")</span>

			<span class="col"><b>Horário Síncrono:</b> @SelectedTurma.HorarioSincronoInicio.Value.ToString("HH:mm") - @SelectedTurma.HorarioSincronoFim.Value.ToString("HH:mm")</span>
		</div>
		
		<div class="row">
			<span class="col-4"><b>Ano Letivo:</b> @(SelectedTurma.AnoLetivo?.Nome ?? "Não definido")</span>
			<span class="col"><b>Carga Horária:</b> @SelectedTurma.CargaHoraria</span>
			
				
		
		</div>
		<div class="row">
			<span class="col-4"><b>Data Início:</b> @SelectedTurma.DataInicioCurso.Value.ToString("dd/MM/yyyy")</span>
			<span class="col"><b>Duração do curso:</b> @($"{SelectedTurma.Curso.DuracaoHoras}h")</span>
		</div>
		@*INICIO #008*@
		@*Adicionei a data de final de curso.*@
		<div class="row">
			<span class="col"><b>Data Fim:</b> @SelectedTurma.DataFimCurso.Value.ToString("dd/MM/yyyy")</span>
		</div>
		@*FIM*@

		<RadzenButton class="mt-4" data-toggle="collapse" data-target="#tabela" Text="Mostrar módulos" ButtonStyle="ButtonStyle.Primary" Icon="expand" />
		<RadzenButton class="mt-4" Text="Ver Sumários" ButtonStyle="ButtonStyle.Primary" Icon="assignment" Click="@(() => navManager.NavigateTo($"Relatorios/{SelectedTurmaId}"))" />		
		<RadzenButton class="mt-4" ButtonStyle="ButtonStyle.Success" Text="Guardar" Icon="calendar_today" Click="@(() => GuardarCalendario(SelectedTurma))" />
		@if (changesMade)
		{
			<i>Tem alterações por guardar.</i>
		}
	}

	@*
		#region TabelasDatasModulos
	*@

	<div class="collapse" id="tabela">
		<table class="table table-striped">
			<thead>
				<tr>
					<th>Código</th>
					<th>Módulo</th>
					@*INICIO #008*@
					@*Adicionar o nome dos Formadores*@
					<th>Formadores</th>
					@*FIM*@
					<th>Horas</th>
				</tr>
			</thead>
			<tbody>
				@if (SelectedTurma != null)
				{
					@foreach (var moduloHora in SelectedTurma.Curso.Modulos)
					{
						<tr>
							<td>M@(moduloHora.Key.Id)</td>
							<td>@moduloHora.Key.Nome</td>
							@*INICIO #008*@
							@*Adicionar o nome dos Formadores*@
							<td>
								@foreach (var formador in SelectedTurma.Modulos.Where(m => m.Id == moduloHora.Key.Id).Select(m => m.Formador))
								{
									<span>@formador.Nome</span><br />
								}
							</td>
							@*FIM*@
							<td>@(HorasPorModulo.ContainsKey(moduloHora.Key.Id) ? HorasPorModulo[moduloHora.Key.Id] : "0")/@(moduloHora.Value)h</td>
						</tr>
					}
				}
			</tbody>
		</table>
	</div>
	@*
		#endregion

		#region Calendário
	*@

	<br />
	<br />

	<SfSchedule TValue="AppointmentData" @ref="Scheduler" @bind-SelectedDate="@CurrentDate" @bind-CurrentView="@CurrentView" CssClass="schedule-cell-dimension">
		<ScheduleTimeScale Interval="60" SlotCount="2"></ScheduleTimeScale>
		<ScheduleResources>
			<ScheduleEvents TValue="AppointmentData" OnPopupOpen="OnPopupOpen" ActionCompleted="OnActionCompleted"></ScheduleEvents>

			<ScheduleResource TItem="ResourceData" TValue="int" DataSource="@OwnerData" Field="OwnerId" Title="Owner"
			Name="Owner" TextField="Text" IdField="Id" ColorField="Color"></ScheduleResource>
		</ScheduleResources>

		<ScheduleEventSettings DataSource="@DataSource"></ScheduleEventSettings>

		<ScheduleQuickInfoTemplates TemplateType="TemplateType.Both">
			<HeaderTemplate>
    <div class="quick-info-header" style="position: relative;">
        <button type="button"
        class="quick-info-close"
        @onclick="@(() => Scheduler.CloseQuickInfoPopup())">
    ×
</button>
        <div class="quick-info-header-content" style="@(GetHeaderStyles((context as AppointmentData)))">
						<div class="quick-info-title">
							@((context as AppointmentData).OwnerId == 0 ? "Calendarizar dia" : (context as AppointmentData).Subject)
						</div>
						<div class="duration-text">
							@((context as AppointmentData).StartTime.ToString("dd/MM/yyyy") + " (" + (context as AppointmentData).StartTime.ToString("HH:mm") + "-" + (context as AppointmentData).EndTime.ToString("HH:mm") + ")")
						</div>
					</div>
				</div>
			</HeaderTemplate>
			<ContentTemplate>

				@if ((context as AppointmentData).ElementType == "cell")
				{
					<div class="content-area">
						<label>Selecionar Módulo/Interrupção</label>
						<SfDropDownList TValue="string" TItem="SelectResourceItem" DataSource="@SelectResourceList" @bind-Value="eventForm.ModuloName" Placeholder="Escolher Módulo/Interrupção">
							<DropDownListFieldSettings Value="Text" Text="Text"></DropDownListFieldSettings>
						</SfDropDownList>
					</div>
					if (eventForm.ModuloName != null)
						eventForm.ModuloId = SelectResourceList.Find(sr => sr.Text == eventForm.ModuloName).ModuloId;
					@if (eventForm.ModuloId != 0)
					{
						<div class="content-area">
							<SfCheckBox Label="Síncrono" @bind-Checked="eventForm.Sincrono"></SfCheckBox>
							@if (eventForm.Sincrono)
							{
								<SfTimePicker TValue="DateTime?" @bind-Value="eventForm.SincronoStart" Step=15 Format="HH:mm"></SfTimePicker>
								<SfTimePicker TValue="DateTime?" @bind-Value="eventForm.SincronoEnd" Step=15 Format="HH:mm"></SfTimePicker>
							}
						</div>
						<div class="content-area">
							<SfCheckBox Label="Assíncrono" @bind-Checked="eventForm.Assincrono"></SfCheckBox>
							@if (eventForm.Assincrono)
							{
								<SfTimePicker TValue="DateTime?" @bind-Value="eventForm.AssincronoStart" Step=15 Format="HH:mm"></SfTimePicker>
								<SfTimePicker TValue="DateTime?" @bind-Value="eventForm.AssincronoEnd" Step=15 Format="HH:mm"></SfTimePicker>
							}
						</div>
						<div class="content-area">
							<SfCheckBox Label="Duração Total Módulo?" @bind-Checked="eventForm.FullModulo"></SfCheckBox>
						</div>
						<div class="content-area">
							@if (!eventForm.FullModulo)
							{
								<label>Número de dias?</label>
								<SfNumericTextBox TValue="int" @bind-Value="@eventForm.Days"></SfNumericTextBox>
							}
						</div>
					}
					else
					{
						<div class="content-area">
							<label>Notas</label>
							<SfTextBox @bind-Value="@eventForm.Description"></SfTextBox>
						</div>
						<div class="content-area">
							<label>Número de dias?</label>
							<SfNumericTextBox TValue="int" @bind-Value="@eventForm.Days"></SfNumericTextBox>
						</div>
					}
				}
				else
				{
					AppointmentData data = context as AppointmentData;
					<div class="event-content">
						<div class="meeting-type-wrap">
							<label>Disciplina</label>:
							<span>@(data.Subject)</span>
						</div>
						<div class="meeting-subject-wrap">
							<label>Tipo</label>:
							<span>@((data.OwnerId != 0) ? OwnerData.Where(item => item.Id.Equals(data.OwnerId)).FirstOrDefault().Text : "")</span>
						</div>
					</div>
				}
			</ContentTemplate>
			<FooterTemplate>
				@if ((context as AppointmentData).ElementType == "cell")
				{
					<div class="cell-footer">
						<RadzenButton ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Text="Adicionar" Click="@(async () => await AdicionarEvento(eventForm, (context as AppointmentData)))" />
					</div>
				}
				else
				{
					<div class="cell-footer">
						<!--INICIO #008-->
						<!--Alterada lógica para o botão Apagar só aparecer se a aul não for Sumarizada-->
						@if (!((context as AppointmentData).Subject == "Aula Sumarizada"))
						{
							<RadzenButton class="px-4" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Text="Apagar" Click="@(e => OnDelete((context as AppointmentData)))" />
						}
						<!--FIM #008-->
						@if ((context as AppointmentData).OwnerId == 3)
						{
							<RadzenButton ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Text="Ver Detalhes" Click="@(() => navManager.NavigateTo($"DetalhesAula/{(context as AppointmentData).Id}"))" />
							<RadzenButton ButtonStyle="ButtonStyle.Primary" Icon="grid_on" Size="ButtonSize.Small" Text="Exportar" Click="@(args => ExportarExcel(".xlsx", (context as AppointmentData).Id))" />
						}
						else if ((context as AppointmentData).Subject.Contains("Síncrono"))
						{
							<RadzenButton ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Text="Criar sumário" Click="@(async () => CriarSumario((context as AppointmentData)))" />
						}
					</div>
				}
			</FooterTemplate>
		</ScheduleQuickInfoTemplates>
		<ScheduleViews>
			<ScheduleView Option="View.WorkWeek" StartHour="08:00" EndHour="20:00" DisplayName="Semanal" FirstDayOfWeek="1"></ScheduleView>
			<ScheduleView Option="View.Month" MaxEventsPerRow="4" ShowWeekend="false" DisplayName="Mensal"></ScheduleView>
			<ScheduleView Option="View.TimelineYear" MaxEventsPerRow="1" DisplayName="Anual" IsSelected="true">
				<EventTemplate>
					<div class="e-appointment-details">
						<div class="e-subject e-text-center">@((context as AppointmentData).Subject)</div>
					</div>
				</EventTemplate>
			</ScheduleView>
		</ScheduleViews>
	</SfSchedule>
	@*
		#endregion
	*@
</div>

<!-- INÍCIO #008 -->
<!-- Botão de Voltar -->
<div class="row justify-content-center">
	<div class="col-md-12 d-flex align-items-end justify-content-center" style="margin-top: 16px;">
		<!-- <RadzenButton ButtonType="ButtonType.Submit" ButtonStyle="ButtonStyle.Success" Icon="save" Text="Guardar" Click="@(() => MarcarFaltas())" /> -->
		@if (changesMade)
		{
			<RadzenButton ButtonStyle="ButtonStyle.Secondary" Disabled="true" Icon="cancel" style="display: inline-block; margin-left: 10px;" Text="Voltar" Click="@(() => navManager.NavigateTo($"Index"))" />
			<i>Tem alterações por guardar.</i>
		}
		else
		{
			<RadzenButton ButtonStyle="ButtonStyle.Secondary" Icon="cancel" style="display: inline-block; margin-left: 10px;" Text="Voltar" Click="@(() => navManager.NavigateTo($"Index"))" />
		}
	</div>
</div>
<br />
<!-- FIM -->


@code {

	[Parameter]
	public int Id { get; set; }

	// INÍCIO #008
	// Chamar as variaveis Idf e Idt para o botão de voltar
	// Also chamar a variavel source para o botão de voltar
	[Parameter]
	public int Idf { get; set; } // Formador ID

	[Parameter]
	public int Idt { get; set; } // Turma ID

	[Parameter]
	public string? source { get; set; }

	// INICIO #008
	// Lista de modulos com Formador
	List<Modulo> modulos;
	// FIM

	// Lista de todas as turmas existentes na bd
	List<Turma> turmas = new List<Turma>();

	// Turma Selectionada pelo dropdown
	int SelectedTurmaId;
	Turma SelectedTurma;

	//Aulas associadas à turma selecionada
	List<Aula> aulas = new List<Aula>();

	//Dicionário com as horas que estão contabilizadas no calendário
	Dictionary<int, double> HorasPorModulo = new Dictionary<int, double>();

	Dictionary<int, Formador> FormadoresTurma = new Dictionary<int, Formador>();

	bool changesMade = false;

	#region VariaveisSfScheduler

	SfSchedule<AppointmentData> Scheduler;
	SfTextBox SubjectRef;
	SfTextBox DescriptionRef;
	SfDropDownList<int, ResourceData> EventTypeRef;
	// determina a vista actual do Scheduler. Ao início é TimelineYear
	View CurrentView = View.TimelineYear;

	//Data para qual o Scheduler está apontado.
	DateTime CurrentDate = DateTime.Now;

	//Lista de todos os eventos no Scheduler
	List<AppointmentData> DataSource = new List<AppointmentData>();

	//ResourceData são grupos de eventos
	//é o que permite ter cores e agrupamento de eventos
	List<ResourceData> OwnerData = new List<ResourceData>();
	List<SelectResourceItem> SelectResourceList = new List<SelectResourceItem>();

	#endregion

	//Objecto que guarda as informações do popup do Scheduler
	//Como se fosse um ViewModel para o form
	EventForm eventForm = new EventForm();

	protected override async Task OnInitializedAsync()
	{
		// INICIO #008
		// Carregar os formadores da turma selecionada
		modulos = moduloData.GetModulosComFormadorByTurma(Id);
		// FIM

		turmas = turmaData.GetAll();
		if (Id != 0)
		{
			SelectedTurmaId = Id;
			OnTurmaSelected();
		}
	}



	/// <summary>
	/// Prepara a página para quando uma turma é selecionada
	/// </summary>
	void OnTurmaSelected()
	{
		DataSource.Clear();

		SelectedTurma = turmas.Single(t => t.Id == SelectedTurmaId);
		SelectedTurma.Curso = cursoData.GetById(SelectedTurma.CursoId.Value);
		SelectedTurma.Modulos = moduloData.GetModulosComFormadorByTurma(SelectedTurmaId);

		var result = moduloData.GetModuloFormadorByTurma(SelectedTurma);
		foreach (var moduloHora in SelectedTurma.Curso.Modulos)
		{
			SelectedTurma.Curso.Modulos[moduloHora.Key] = result[moduloHora.Key.Id].Horas;
		}

		SelectedTurma.Aulas = aulaData.GetByTurma(SelectedTurma);

		//Aponta a vista do calendário para o ínicio do curso da turma
		CurrentDate = SelectedTurma.DataInicioCurso.Value;

		//criar uma lista de ResourceData para selecionar a que módulo/interrupção pertence o evento
		CreateResourceData();

		//inicializar os valores do form de criação de evento para os valores defeito da turma
		eventForm = new EventForm
				{
					Sincrono = true,
					SincronoStart = SelectedTurma.HorarioSincronoInicio,
					SincronoEnd = SelectedTurma.HorarioSincronoFim,
					Assincrono = true,
					AssincronoStart = SelectedTurma.HorarioAssincronoInicio,
					AssincronoEnd = SelectedTurma.HorarioAssincronoFim,
					Days = 1,
					FullModulo = true
				};

		//se existir uma calendarização prévia, carrega-a
		string calendarPath = env.ContentRootPath + $"/Files/Calendars/{SelectedTurma.Id}.json";
		if (File.Exists(calendarPath))
		{
			string calendarJson = File.ReadAllText(calendarPath);
			DataSource = JsonConvert.DeserializeObject<List<AppointmentData>>(calendarJson);
		}
		else
		{
			DataSource.Clear();
		}

		//Para cada aula que já tenha sido sumarizada, colocar o evento correstpondente no grupo certo (OwnerId = 3)
		foreach (var aula in SelectedTurma.Aulas.OrderBy(a => a.HoraInicio))
		{
			var apt = DataSource.Find(apt => apt.StartTime == aula.HoraInicio && apt.OwnerId != 3);
			if (apt != null)
			{
				apt.OwnerId = 3;
				apt.IsReadonly = true;
				apt.Id = aula.Id;
				apt.Subject = "Aula Sumarizada";
				apt.Formador = aula.Formador;
			}
		}
		CalcularHorasPorModulo();
	}

	/// <summary>
	/// Cria uma lista de Grupos consoante os módulos que existam no Curso da turma Selecionada
	/// isto permito agrupar aulas pelos módulos
	/// </summary>
	void CreateResourceData()
	{
		OwnerData.Clear();
		SelectResourceList.Clear();
		OwnerData.Add(new ResourceData { Id = 1, Color = "#ff5555", Text = "Interrupção Paga" });
		OwnerData.Add(new ResourceData { Id = 2, Color = "#ff4466", Text = "Interrupção Não Paga" });
		OwnerData.Add(new ResourceData { Id = 3, Color = "#5db774", Text = "Aulas Sumarizadas" });
		SelectResourceList.Add(new SelectResourceItem { ModuloId = 0, Text = "Interrupção Paga" });
		SelectResourceList.Add(new SelectResourceItem { ModuloId = 0, Text = "Interrupção Não Paga" });

		int resourceDataId = 4;
		foreach (var modulo in SelectedTurma.Curso.Modulos.Keys)
		{
			OwnerData.Add(new ResourceData
					{
						Id = resourceDataId,
						Color = "#479cc8",
						Text = $"M{modulo.Id} - Síncrono",
						ModuloId = modulo.Id
					});
			resourceDataId++;
			OwnerData.Add(new ResourceData
					{
						Id = resourceDataId,
						Color = "#479ca8",
						Text = $"M{modulo.Id} - Assíncrono",
						ModuloId = modulo.Id
					});
			resourceDataId++;
			SelectResourceList.Add(new SelectResourceItem { ModuloId = modulo.Id, Text = $"M{modulo.Id}" });
		}
	}

	/// <summary>
	/// Guarda o calendário como ficheiro json em que o nome no ficheiro é o id da turma
	/// </summary>
	void GuardarCalendario(Turma turma)
	{
		try
		{
			Directory.CreateDirectory(Path.Combine($"{env.ContentRootPath}", "Files", "Calendars"));
		}
		catch { }
		var calendarAsJson = JsonConvert.SerializeObject(DataSource);
		File.WriteAllText(env.ContentRootPath + $"/Files/Calendars/{turma.Id}.json", calendarAsJson);
		changesMade = false;
	}

	/// <summary>
	/// Calcula o número de horas que estão marcadas por módulo
	/// Guarda o resultado no dicionário HorasPorModulo
	/// </summary>
	void CalcularHorasPorModulo()
	{
		HorasPorModulo.Clear();
		foreach (var apt in DataSource)
		{
			var totalHoras = (apt.EndTime - apt.StartTime).TotalHours;
			var recurStr = apt.RecurrenceRule;
			if (recurStr != null)
			{
				recurStr = recurStr.Substring(recurStr.IndexOf("UNTIL=") + 6, 8);
				var until = DateTime.ParseExact(recurStr, "yyyyMMdd", CultureInfo.InvariantCulture);

				totalHoras *= (until - apt.StartTime.Date).TotalDays;
			}

			if (HorasPorModulo.ContainsKey(apt.ModuloId))
			{
				HorasPorModulo[apt.ModuloId] += totalHoras;
			}
			else
			{
				HorasPorModulo.Add(apt.ModuloId, totalHoras);
			}
		}
	}

	/// <summary>
	/// Adicionia eventos novos ao calendário.
	/// Se o novo evento for uma interrupção, empurra todos os eventos (que não sejam interrupções ou aulas sumarizadas) para a frente
	/// se o novo evento for uma calendarização de aula, salta interrupções que possa encontrar para a duração introduzida
	/// </summary>
	async Task AdicionarEvento(EventForm eventForm, AppointmentData data)
	{
		//fechar a janela do EventForm
		Scheduler.CloseQuickInfoPopup();

		//determinar data selectionada
		var dateSelected = data.StartTime.Date;

		//eventForm tem que ir buscar o id do módulo à lista de Recursos
		eventForm.ModuloId = SelectResourceList.Find(sr => sr.Text == eventForm.ModuloName).ModuloId;

		var daysLeft = eventForm.Days;
		//se foi selecionada a opção de prenchimento para a duração total do módulo
		if (eventForm.FullModulo && eventForm.ModuloId != 0)
		{
			//que modulo foi selectionado?
			var moduloSelected = SelectedTurma.Curso.Modulos.FirstOrDefault(mh => mh.Key.Id == eventForm.ModuloId).Key;
			//quantas horas ele dura?
			double hoursModuloSelected = SelectedTurma.Curso.Modulos[moduloSelected];
			//em quandos dias se traduzem essas horas?
			daysLeft = (int)(hoursModuloSelected / SelectedTurma.CargaHoraria);
		}
		while (daysLeft >= 1)
		{
			if (eventForm.ModuloId != 0) //se não é uma interrupção
			{
				//se existirem interrupções pagas ou não pagas na data selectionada, saltar um dia útil à frente até encontrar um dia livre
				if (DataSource.Where(apt => apt.StartTime.Date == dateSelected && (apt.OwnerId == 1 || apt.OwnerId == 2)).Count() > 0)
				{
					do
					{
						dateSelected = dateSelected.AddWorkingDays(1);
					} while (DataSource.Where(apt => apt.StartTime.Date == dateSelected && (apt.OwnerId == 1 || apt.OwnerId == 2)).Count() != 0);
				}

				if (eventForm.Sincrono)
				{
					var sinApt = new AppointmentData
							{
								Id = new Random().Next(),
								StartTime = dateSelected + eventForm.SincronoStart.Value.TimeOfDay,
								EndTime = dateSelected + eventForm.SincronoEnd.Value.TimeOfDay,
								Subject = $"{eventForm.ModuloName} - Síncrono",
								ElementType = "event",
								OwnerId = OwnerData.Find(o => o.ModuloId == eventForm.ModuloId && o.Text.Contains("Síncrono")).Id,
								ModuloId = eventForm.ModuloId,
								ModuloName = eventForm.ModuloName,
								Formador = SelectedTurma.Modulos.Where(m => m.Id == eventForm.ModuloId).Select(m => m.Formador).FirstOrDefault()
							};
					DataSource.Add(sinApt);
				}
				if (eventForm.Assincrono)
				{
					var assApt = new AppointmentData
							{
								Id = new Random().Next(),
								StartTime = dateSelected + eventForm.AssincronoStart.Value.TimeOfDay,
								EndTime = dateSelected + eventForm.AssincronoEnd.Value.TimeOfDay,
								Subject = $"{eventForm.ModuloName} - Assíncrono",
								ElementType = "event",
								OwnerId = OwnerData.Find(o => o.ModuloId == eventForm.ModuloId && o.Text.Contains("Assíncrono")).Id,
								ModuloId = eventForm.ModuloId,
								ModuloName = eventForm.ModuloName,
								Formador = SelectedTurma.Modulos.Where(m => m.Id == eventForm.ModuloId).Select(m => m.Formador).FirstOrDefault()
							};
					DataSource.Add(assApt);
				}
			}
			else
			{
				var intApt = new AppointmentData
						{
							Id = new Random().Next(),
							IsAllDay = true,
							StartTime = dateSelected,
							EndTime = dateSelected,
							Subject = eventForm.ModuloName,
							OwnerId = OwnerData.Find(o => o.Text.Contains(eventForm.ModuloName)).Id,
							ModuloName = eventForm.ModuloName,
							Description = eventForm.Description
						};

				foreach (var apt in DataSource.Where(apt => (apt.StartTime.Date >= dateSelected && apt.ModuloId != 0 && apt.OwnerId != 3)))
				{
					do
					{
						apt.AddWorkingDays(1);
					} while (DataSource.Where(futureApt => futureApt.StartTime.Date == apt.StartTime.Date && (futureApt.OwnerId == 1 || futureApt.OwnerId == 2)).Count() != 0);
				}

				DataSource.Add(intApt);
			}
			daysLeft--;
			dateSelected = dateSelected.AddWorkingDays(1);
		}
		CalcularHorasPorModulo();
		changesMade = true;
		await Task.Run(async () => await this.Scheduler.RefreshEvents());
	}

	/// <summary>
	///Prepara um objecto aula guarda em SessionStorage e redireciona para a página de detalhes de
	/// </summary
	async Task CriarSumario(AppointmentData data)
	{
		if (changesMade)
			GuardarCalendario(SelectedTurma);

		Aula novaAula = new Aula
		{
			HoraInicio = data.StartTime,
			HoraFim = data.EndTime,
			TurmaId = SelectedTurmaId,
			ModuloId = data.ModuloId,
			FormadorId = data.Formador.Id,
		};
		await sessionStorage.SetAsync("CriarAula", JsonConvert.SerializeObject(novaAula));
		navManager.NavigateTo($"DetalhesAula/{novaAula.Id}/{novaAula.FormadorId}/{novaAula.TurmaId}/Calendar");
	}

