	// EXPORTAR EXCEL
	/// <summary>
	/// Usando ClosedXML https://github.com/closedxml/closedxml/wiki
	/// 1: Criar um novo workbook, com uma worksheet
	/// 2: Preencher e formatar as células com o conteúdo
	/// 3: Exportar usando SaveAsExcel ou SaveAsCSV dentro de SaveFile.js
	/// </summary>
	async void ExportarExcel(string extension, int contextId)
	{
		IXLWorkbook workbook = new XLWorkbook();
		IXLWorksheet worksheet = workbook.Worksheets.Add("aulas");

		Aula aula = SelectedTurma.Aulas.FirstOrDefault(a => a.Id == contextId);
		List<Formador> formadores = formadorData.GetAll();
		List<Formando> formandos = formandoData.GetAllByTurma(SelectedTurmaId);
		List<Falta> faltas = faltaData.GetAll();

		#region Template Topo
		var currentRow = 1;
		var currentColumn = 1;

		//Imagens Topo
		worksheet.AddPicture("wwwroot/img/pauta/iefp.png")
					.MoveTo(worksheet.Cell(currentRow, currentColumn));
		currentColumn += 3;
		worksheet.AddPicture("wwwroot/img/pauta/iscte.png")
					.MoveTo(worksheet.Cell(currentRow, currentColumn))
					.Scale(.07);
		currentColumn += 3;
		worksheet.AddPicture("wwwroot/img/pauta/upskill.png")
				.MoveTo(worksheet.Cell(currentRow, currentColumn));

		currentRow += 5;
		currentColumn -= 6;
		#endregion

		#region Corpo


		#region Cabeçalho
		var rngCabeçalhoFirstRow = currentRow;
		var rngCabeçalhoFirstColumn = currentColumn;

		worksheet.Cell(currentRow, currentColumn++).Value = "Módulo";
		worksheet.Cell(currentRow++, currentColumn--).Value = aula.ModuloId == null ? "Sem módulo" : moduloData.GetById((int)aula.ModuloId).Nome;
		worksheet.Cell(currentRow, currentColumn++).Value = "Data";
		worksheet.Cell(currentRow++, currentColumn--).Value = aula.HoraInicio.Date;
		worksheet.Cell(currentRow, currentColumn++).Value = "Duração da Aula";
		worksheet.Cell(currentRow++, currentColumn--).Value = aula.DuracaoHoras;
		worksheet.Cell(currentRow, currentColumn++).Value = "Formador";
		worksheet.Cell(currentRow++, currentColumn).Value = formadorData.GetById(Convert.ToInt32(aula.FormadorId)).Nome;
		//Sumário é escrito depois dos formandos

		//Vertical
		var rngCabeçalho = worksheet.Range(rngCabeçalhoFirstRow, rngCabeçalhoFirstColumn, currentRow, rngCabeçalhoFirstColumn);
		rngCabeçalho.Style.Font.FontName = "Century Gothic";
		rngCabeçalho.Style.Font.FontSize = 15;
		rngCabeçalho.Style.Font.Bold = true;
		rngCabeçalho.Style.Fill.BackgroundColor = XLColor.FromArgb(204, 255, 255);
		//Horizontal
		rngCabeçalho = worksheet.Range(rngCabeçalhoFirstRow, rngCabeçalhoFirstColumn + 2, rngCabeçalhoFirstRow, rngCabeçalhoFirstColumn + 4);
		rngCabeçalho.Style.Font.FontName = "Century Gothic";
		rngCabeçalho.Style.Font.FontSize = 15;
		rngCabeçalho.Style.Font.Bold = true;
		rngCabeçalho.Style.Fill.BackgroundColor = XLColor.FromArgb(204, 255, 255);

		currentRow = rngCabeçalhoFirstRow;
		currentColumn++;

		worksheet.Cell(currentRow, currentColumn++).Value = "Formando";
		worksheet.Cell(currentRow, currentColumn++).Value = "Falta Justificada";
		worksheet.Cell(currentRow++, currentColumn).Value = "Falta Inustificada";

		currentColumn -= 2;

		foreach (var formando in formandos)
		{
			worksheet.Cell(currentRow, currentColumn++).Value = formando.Nome;

			double faltaJus = 0;
			double faltaInjus = 0;

			foreach (var falta1 in faltas.Where(n => n.FormandoId == formando.Id && n.AulaId == aula.Id))
			{
				if (falta1.Justificada)
				{
					faltaJus = falta1.Duracao;
				}
				else
				{
					faltaInjus = falta1.Duracao;
				}
			}
			worksheet.Cell(currentRow, currentColumn++).Value = faltaJus / 60.0;
			worksheet.Cell(currentRow++, currentColumn).Value = faltaInjus / 60.0;

			currentColumn -= 2;
		}
		#endregion

		worksheet.Cell(rngCabeçalhoFirstRow + 4, rngCabeçalhoFirstColumn).Value = "Sumário";
		//worksheet.Cell(rngCabeçalhoFirstRow + 6, rngCabeçalhoFirstColumn).Value = aula.Sumario;
		worksheet.Range(11, 1, 12, 2)
				.SetValue(aula.Sumario)
				.Merge()
				.Style
					.Alignment.SetHorizontal(XLAlignmentHorizontalValues.Left)
					.Alignment.SetVertical(XLAlignmentVerticalValues.Top)
					.Alignment.SetWrapText(true);
		//worksheet.Cell(rngCabeçalhoFirstRow + 6, rngCabeçalhoFirstColumn).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Left;
		//worksheet.Cell(rngCabeçalhoFirstRow + 6, rngCabeçalhoFirstColumn).Style.Alignment.Vertical = XLAlignmentVerticalValues.Top;
		//worksheet.Cell(rngCabeçalhoFirstRow + 6, rngCabeçalhoFirstColumn).Style.Alignment.WrapText = true;
		//worksheet.Range(rngCabeçalhoFirstRow + 6, rngCabeçalhoFirstColumn, currentRow - 1, currentColumn - 1).SetValue(aula.Sumario).Merge();


		var rngGrupo = worksheet.Range(rngCabeçalhoFirstRow, rngCabeçalhoFirstColumn, currentRow - 1, currentColumn + 2);
		rngGrupo.Columns().Style.Border.OutsideBorder = XLBorderStyleValues.Thin;
		rngGrupo.Cells().Style.Alignment.SetHorizontal(XLAlignmentHorizontalValues.Left);

		currentRow += 2;
		currentColumn = rngCabeçalhoFirstColumn;

		worksheet.Columns().AdjustToContents();
		#endregion


		#region Template rodapé
		currentRow += 3;
		worksheet.AddPicture("wwwroot/img/pauta/gov.jpg")
					.MoveTo(worksheet.Cell(currentRow + 3, 4))
					.Scale(.74);
		#endregion

		var timestamp = Convert.ToString(DateTime.Now);

		await fileManager.DownloadWorkbook(workbook, extension, timestamp + "_Aulas");
	}


