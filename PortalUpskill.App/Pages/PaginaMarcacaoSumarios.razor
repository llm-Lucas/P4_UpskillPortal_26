@attribute [Authorize(Roles = "Formador")]
@page "/Sumarios"
@page "/Sumarios/{Id:int}"

@inject NavigationManager Navigation
@inject IWebHostEnvironment env
@inject ITurmaData turmaData
@inject ICursoData cursoData
@inject IAulaData aulaData
@inject IPessoaData pessoaData
@inject IFormadorData formadorData
@inject IModuloData moduloData
@inject ProtectedSessionStorage sessionStorage
@inject FileManagerService fileManager
@using System.Globalization

<div class="cardstyle">
    <div style="display: flex; gap: 1rem; align-items: flex-start;">
        <div style="flex:1">
            <h3>Selecione uma turma</h3>
            <RadzenDropDown class="w-75" Data="@turmas" @bind-Value="SelectedTurmaId" Change="OnTurmaSelected" TValue="int" ValueProperty="Id" TextProperty="Nome"
                            AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                            AllowClear="false">
                <Template Context="turmaItem">
                    <span>@turmaItem.Nome - @turmaItem.Curso.Nome</span>
                </Template>
            </RadzenDropDown>
        </div>
    </div>

    @if (SelectedTurma != null)
    {
        <div class="row">
            @if (SelectedTurma.HorarioAssincronoInicio.HasValue && SelectedTurma.HorarioAssincronoFim.HasValue)
            {
                <span class="col-4"><b>Horário Assíncrono:</b> @SelectedTurma.HorarioAssincronoInicio.Value.ToString("HH:mm") - @SelectedTurma.HorarioAssincronoFim.Value.ToString("HH:mm")</span>
            }
            @if (SelectedTurma.HorarioSincronoInicio.HasValue && SelectedTurma.HorarioSincronoFim.HasValue)
            {
                <span class="col"><b>Horário Síncrono:</b> @SelectedTurma.HorarioSincronoInicio.Value.ToString("HH:mm") - @SelectedTurma.HorarioSincronoFim.Value.ToString("HH:mm")</span>
            }
        </div>
        <div class="row">
            <span class="col-4"><b>Ano Letivo:</b> @(SelectedTurma.AnoLetivo?.Nome ?? "Não definido")</span>
            @if (SelectedTurma.HorarioAssincronoInicio.HasValue && SelectedTurma.HorarioAssincronoFim.HasValue && SelectedTurma.HorarioSincronoInicio.HasValue && SelectedTurma.HorarioSincronoFim.HasValue)
            {
                <span class="col"><b>Carga Horária:</b> @SelectedTurma.CargaHoraria</span>
            }
            else
            {
                <span class="col"><b>Carga Horária:</b> Não definida</span>
            }
        </div>
        @if (SelectedTurma.DataInicioCurso.HasValue)
        {
            <div class="row">
                <span class="col-4"><b>Data Início:</b> @SelectedTurma.DataInicioCurso.Value.ToString("dd/MM/yyyy")</span>
                <span class="col"><b>Duração do curso:</b> @($"{SelectedTurma.Curso.DuracaoHoras}h")</span>
            </div>
        }
        @if (SelectedTurma.DataFimCurso.HasValue)
        {
            <div class="row">
                <span class="col"><b>Data Fim:</b> @SelectedTurma.DataFimCurso.Value.ToString("dd/MM/yyyy")</span>
            </div>
        }

        <RadzenButton class="mt-4" data-toggle="collapse" data-target="#tabela" Text="Mostrar módulos" ButtonStyle="ButtonStyle.Primary" Icon="expand" />
        <RadzenButton class="mt-4" Text="Download" ButtonStyle="ButtonStyle.Primary" Icon="file_download" Click="Exportar" />

        <div class="collapse" id="tabela">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Módulo</th>
                        <th>Horas</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var moduloHora in SelectedTurma.Curso.Modulos)
                    {
                        <tr>
                            <td>M@(moduloHora.Key.Id)</td>
                            <td>@moduloHora.Key.Nome</td>
                            <td>@(HorasPorModulo.ContainsKey(moduloHora.Key.Id) ? HorasPorModulo[moduloHora.Key.Id] : "0")/@(moduloHora.Value)h</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <h3 style="margin-top: 25px;"></h3>

        @if (DataSource.Count > 0)
        {
            <SfSchedule TValue="AppointmentData" @ref="Scheduler" @bind-SelectedDate="@CurrentDate" @bind-CurrentView="@CurrentView">
                <ScheduleResources>
                    <ScheduleEvents TValue="AppointmentData" OnPopupOpen="@OnPopupOpen"></ScheduleEvents>
                    <ScheduleResource TItem="ResourceData" TValue="int" DataSource="@OwnerData" Field="OwnerId" Title="Owner"
                                      Name="Owner" TextField="Text" IdField="Id" ColorField="Color"></ScheduleResource>
                </ScheduleResources>
                <ScheduleEventSettings DataSource="@DataSource"></ScheduleEventSettings>
                <ScheduleQuickInfoTemplates TemplateType="TemplateType.Both">
                    <HeaderTemplate>
                        <div class="quick-info-header">
                            <div class="quick-info-header-content" style="@(GetHeaderStyles((context as AppointmentData)))">
                                <div class="quick-info-title">
                                    @((context as AppointmentData).OwnerId == 0 ? "Calendarizar dia" : (context as AppointmentData).Subject)
                                </div>
                                <div class="duration-text">
                                    @((context as AppointmentData).StartTime.ToString("dd/MM/yyyy") + " (" + (context as AppointmentData).StartTime.ToString("HH:mm") + "-" + (context as AppointmentData).EndTime.ToString("HH:mm") + ")")
                                </div>
                            </div>
                        </div>
                    </HeaderTemplate>
                    <ContentTemplate>
                        @if ((context as AppointmentData).ElementType != "cell")
                        {
                            AppointmentData Data = context as AppointmentData;
                            <div class="event-content">
                                <div class="meeting-type-wrap">
                                    <label>Disciplina</label>:
                                    <span>@(Data.Subject)</span>
                                </div>
                                <div class="meeting-subject-wrap">
                                    <label>Tipo</label>:
                                    <span>@((Data.OwnerId != 0) ? OwnerData.Where(item => item.Id.Equals(Data.OwnerId)).FirstOrDefault().Text : "")</span>
                                </div>
                            </div>
                        }
                    </ContentTemplate>
                    <FooterTemplate>
                        @if ((context as AppointmentData).ElementType == "cell")
                        {
                        }
                        else
                        {
                            <div class="cell-footer">
                                @if ((context as AppointmentData).OwnerId == 3)
                                {
                                    <RadzenButton ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Text="Ver Detalhes" Click="@(() => navManager.NavigateTo($"DetalhesAula/{(context as AppointmentData).Id}/{Idf}/{Idt}/Sumarios"))" />
                                }
                                else if ((context as AppointmentData).Subject.Contains("Síncrono"))
                                {
                                    <RadzenButton ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Text="Criar sumário" Click="@(async () => await CriarSumario((context as AppointmentData)))" />
                                }
                            </div>
                        }
                    </FooterTemplate>
                </ScheduleQuickInfoTemplates>
                <ScheduleViews>
                    <ScheduleView Option="View.Week" StartHour="08:00" EndHour="20:00" DisplayName="Semanal"></ScheduleView>
                    <ScheduleView Option="View.Month" MaxEventsPerRow="10" ShowWeekend="false" DisplayName="Mensal"></ScheduleView>
                    <ScheduleView Option="View.TimelineYear" MaxEventsPerRow="3" DisplayName="Anual" IsSelected="true">
                        <EventTemplate>
                            <div class="e-appointment-details">
                                <div class="e-subject e-text-center">@((context as AppointmentData).Subject)</div>
                            </div>
                        </EventTemplate>
                    </ScheduleView>
                </ScheduleViews>
            </SfSchedule>
        }
        else
        {
            <p>Não existem aulas calendarizadas para a turma selecionada.</p>
        }
    }
</div>

<div class="row justify-content-center">
    <div class="col-md-12 d-flex align-items-end justify-content-center" style="margin-top: 16px;">
        <AuthorizeView Roles="Administrador, Secretariado">
            <Authorized>
                <RadzenButton ButtonStyle="ButtonStyle.Secondary" Icon="cancel" style="display: inline-block; margin-left: 10px;" Text="Voltar" Click="@(() => navManager.NavigateTo($"Calendar/{aulaVM.TurmaId}"))" />
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Roles="Formador">
            <Authorized>
                <RadzenButton ButtonStyle="ButtonStyle.Secondary" Icon="cancel" style="display: inline-block; margin-left: 10px;" Text="Voltar" Click="@(GoBack)" />
            </Authorized>
        </AuthorizeView>
    </div>
</div>

@code {
    AulaViewModel aulaVM = new AulaViewModel();

    [Parameter]
    public int Idf { get; set; }

    [Parameter]
    public int Idt { get; set; }

    string? From;
    int? TurmaId;

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        From = query["from"];
        if (From == "detalhes")
        {
            TurmaId = int.Parse(query["turmaId"]);
        }
    }

    void GoBack()
    {
        if (From == "detalhes" && TurmaId.HasValue)
        {
            Navigation.NavigateTo($"/Detalhes/Turma/{TurmaId}");
        }
        else
        {
            Navigation.NavigateTo("/");
        }
    }

    [Parameter]
    public int Id { get; set; }

    List<Turma> turmas = new List<Turma>();
    int SelectedTurmaId;
    Turma SelectedTurma;
    List<Aula> aulas = new List<Aula>();
    Dictionary<int, double> HorasPorModulo = new Dictionary<int, double>();

    SfSchedule<AppointmentData> Scheduler;
    View CurrentView = View.TimelineYear;
    DateTime CurrentDate = DateTime.Now;
    List<AppointmentData> DataSource = new List<AppointmentData>();
    List<ResourceData> OwnerData = new List<ResourceData>();

    Pessoa user;

    [CascadingParameter]
    Task<AuthenticationState> authStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        string userEmail = (await authStateTask).User.Identity.Name;
        user = pessoaData.GetByEmail(userEmail);
        turmas = formadorData.GetTurmaByIdFormador(user.Id);

        List<int> idsAutorizados = turmas.Select(t => t.Id).ToList();
        if (Id != 0 && idsAutorizados.Contains(Id))
        {
            SelectedTurmaId = Id;
            OnTurmaSelected();
        }
    }

    void OnTurmaSelected()
    {
        DataSource.Clear();

        SelectedTurma = turmas.Single(t => t.Id == SelectedTurmaId);
        SelectedTurma.Curso = cursoData.GetById(SelectedTurma.CursoId.Value);
        SelectedTurma.Aulas = aulaData.GetByTurma(SelectedTurma);

        CreateResourceData();

        string calendarPath = env.ContentRootPath + $"/Files/Calendars/{SelectedTurma.Id}.json";
        if (File.Exists(calendarPath))
        {
            string calendarJson = File.ReadAllText(calendarPath);
            DataSource = JsonConvert.DeserializeObject<List<AppointmentData>>(calendarJson);
        }
        else
        {
            DataSource.Clear();
        }

        List<int> modulosFormador = moduloData.GetModuloFormadorByTurma(SelectedTurma)
        .Where(mfh => mfh.Value.FormadorId == user.Id)
        .Select(item => item.Key)
        .ToList();

        DataSource = DataSource.Where(apt => modulosFormador.Contains(apt.ModuloId) && (apt.Subject.Contains("Síncrono") || apt.OwnerId == 3)).ToList();

        DataSource.ForEach(apt => apt.IsReadonly = true);

        foreach (var aula in SelectedTurma.Aulas.OrderBy(a => a.HoraInicio))
        {
            var apt = DataSource.Find(apt => apt.StartTime == aula.HoraInicio && apt.OwnerId != 3);
            if (apt != null)
            {
                apt.OwnerId = 3;
                apt.IsReadonly = true;
                apt.Id = aula.Id;
                apt.Subject = "Aula Sumarizada";
            }
        }
    }

    void CreateResourceData()
    {
        OwnerData.Clear();
        OwnerData.Add(new ResourceData { Id = 3, Color = "#5db774", Text = "Aulas Sumarizadas" });

        int resourceDataId = 4;
        foreach (var modulo in SelectedTurma.Curso.Modulos.Keys)
        {
            OwnerData.Add(new ResourceData { Id = resourceDataId, Color = "#479cc8", Text = $"M{modulo.Id} - Síncrono", ModuloId = modulo.Id });
            resourceDataId++;
            OwnerData.Add(new ResourceData { Id = resourceDataId, Color = "#479ca8", Text = $"M{modulo.Id} - Assíncrono", ModuloId = modulo.Id });
            resourceDataId++;
        }
    }

    async Task CriarSumario(AppointmentData data)
    {
        Aula novaAula = new Aula
                {
                    HoraInicio = data.StartTime,
                    HoraFim = data.EndTime,
                    TurmaId = SelectedTurmaId,
                    ModuloId = data.ModuloId
                };
        await sessionStorage.SetAsync("CriarAula", JsonConvert.SerializeObject(novaAula));
        navManager.NavigateTo($"DetalhesAula/");
    }

    async Task Exportar()
    {
        if (DataSource.Count() == 0)
        {
            dialogService.OpenAsync("Erro", render =>
    @<div class="row justify-content-center">
        Não existe nada para exportar.
    </div>
    , new DialogOptions { Height = "auto", Width = "auto" }
    );
            return;
        }

        IXLWorkbook wb = new XLWorkbook(env.ContentRootPath + "/Files/Calendars/template_cronograma.xlsx");
        IXLWorksheet ws = wb.Worksheet("Calendarização");

        ws.Cell("B1").SetValue(SelectedTurma.Curso.Nome);
        ws.Cell("B2").SetValue(SelectedTurma.Nome);

        Calendar calendar = CultureInfo.InvariantCulture.Calendar;

        DateTime firstDay = DataSource.OrderBy(apt => apt.StartTime).First().StartTime.Date;
        DateTime lastDay = DataSource.OrderByDescending(apt => apt.EndTime).First().StartTime.Date;
        DateTime currentDay = new DateTime(firstDay.Year, firstDay.Month, 1);

        CellPointer c = new(4, 1);
        int monthRowCount = 27;

        while (currentDay.Month <= lastDay.Month || currentDay.Year < lastDay.Year)
        {
            ws.Cell(c.Row, c.Col).SetValue(Meses[currentDay.Month]);
            ws.Range(c.Row, c.Col, ++c.Row, c.Col).Merge().Style.Border.OutsideBorder = XLBorderStyleValues.Thin;
            c.Row++;
            ws.Cell(c.Row++, c.Col).SetValue("Horário").Style.Border.SetOutsideBorder(XLBorderStyleValues.Thin);

            CellPointer hoursColumn = new CellPointer(c.Row, c.Col);
            foreach (var hours in HoursColumnIEnumerable)
                ws.Cell(c.Row++, c.Col).Value = hours;

            ws.Range(hoursColumn.Row, hoursColumn.Col, c.Row - 1, c.Col).Style
                .Border.SetOutsideBorder(XLBorderStyleValues.Thin)
                .Border.SetInsideBorder(XLBorderStyleValues.Thin)
                .Border.SetInsideBorderColor(XLColor.AshGrey);

            c.Row -= monthRowCount;
            c.Col++;

            int daysInMonth = calendar.GetDaysInMonth(currentDay.Year, currentDay.Month);

            for (int i = 1; i <= daysInMonth; i++)
            {
                int dayOfWeek = (int)currentDay.DayOfWeek;

                ws.Cell(c.Row++, c.Col).SetValue(DiaSemana[dayOfWeek]).Style.Border.SetOutsideBorder(XLBorderStyleValues.Thin);
                ws.Cell(c.Row--, c.Col++).SetValue(i).Style.Border.SetOutsideBorder(XLBorderStyleValues.Thin);

                CellPointer dayStart = new CellPointer(c.Row + 3, c.Col - 1);
                CellPointer dayEnd = new CellPointer(c.Row + 26, c.Col - 1);

                ws.Range(dayStart.Row, dayStart.Col, dayEnd.Row, dayEnd.Col).Style
                    .Border.SetOutsideBorder(XLBorderStyleValues.Thin)
                    .Border.SetInsideBorder(XLBorderStyleValues.Thin)
                    .Border.SetInsideBorderColor(XLColor.AshGrey);

                if (dayOfWeek == 0 || dayOfWeek == 6)
                    ws.Range(dayStart.Row, dayStart.Col, dayEnd.Row, dayEnd.Col).Style
                        .Fill.SetBackgroundColor(XLColor.FromArgb(221, 221, 221))
                        .Border.SetInsideBorderColor(XLColor.FromArgb(221, 221, 221));

                var currentDayApts = DataSource.Where(apt => apt.StartTime.Date == currentDay.Date);
                foreach (var apt in currentDayApts)
                {
                    if (apt.OwnerId != 1 && apt.OwnerId != 2)
                    {
                        var startRowOffset = (int)((apt.StartTime.TimeOfDay.TotalHours - 8) * 2);
                        var endRowOffset = (int)((apt.EndTime.TimeOfDay.TotalHours - 8) * 2 - 1);
                        var aptCellRange = ws.Range(dayStart.Row + startRowOffset, dayStart.Col, dayStart.Row + endRowOffset, dayStart.Col);
                        aptCellRange.Merge().Style
                            .Border.SetOutsideBorder(XLBorderStyleValues.Medium)
                            .Border.SetOutsideBorderColor(XLColor.Black)
                            .Border.SetInsideBorder(XLBorderStyleValues.None);
                        string atividade = apt.Subject.Contains("Assíncrono") ? "Autónomo" : "Aula";
                        string formador = apt.Formador != null ? apt.Formador.Nome : "Sem Formador";
                        aptCellRange.Value = $"M{apt.ModuloId}\n\n{formador}\n\n{atividade}";
                    }
                    else
                    {
                        var fillColor = apt.OwnerId == 1 ? XLColor.FromArgb(178, 178, 178) : XLColor.FromArgb(102, 102, 102);
                        ws.Range(dayStart.Row, dayStart.Col, dayEnd.Row, dayEnd.Col)
                            .Merge().SetValue(apt.Subject).Style
                            .Fill.SetBackgroundColor(fillColor);
                    }
                }
                currentDay = currentDay.AddDays(1);
            }

            c.Row += monthRowCount + 2;
            c.Col = 1;
        }

        await fileManager.DownloadWorkbook(wb, filename: $"{SelectedTurma.Nome} Calendarização");
    }

    private string GetHeaderStyles(AppointmentData data)
    {
        try
        {
            if (data.ElementType == "cell")
                return "align-items: center ; color: #919191;";
            else
                return "background:" + this.OwnerData.Where(item => item.Id.Equals(data.OwnerId)).FirstOrDefault().Color + "; color: #FFFFFF;";
        }
        catch (Exception e) { return e.Message; }
    }

    void OnPopupOpen(PopupOpenEventArgs<AppointmentData> args)
    {
        if (args.Type == PopupType.Editor)
            args.Cancel = true;
    }

    public class ResourceData
    {
        public int Id { get; set; }
        public string Text { get; set; }
        public string Color { get; set; }
        public int ModuloId { get; set; }
    }

    public class AppointmentData
    {
        public int Id { get; set; }
        public string Subject { get; set; }
        public string Location { get; set; }
        public DateTime StartTime { get; set; }
        public DateTime EndTime { get; set; }
        public string Description { get; set; }
        public bool IsAllDay { get; set; }
        public string RecurrenceRule { get; set; }
        public string RecurrenceException { get; set; }
        public Nullable<int> RecurrenceID { get; set; }
        public int OwnerId { get; set; }
        public bool IsReadonly { get; set; }
        public string ElementType { get; set; }
        public int ModuloId { get; set; }
        public string ModuloName { get; set; }
        public Formador Formador { get; set; }

        public void AddWorkingDays(int days)
        {
            StartTime = StartTime.AddWorkingDays(1);
            EndTime = EndTime.AddWorkingDays(1);
        }
    }

    class CellPointer
    {
        public CellPointer(int x, int y) { Row = x; Col = y; }
        public int Row { get; set; }
        public int Col { get; set; }
    }

    IEnumerable<string> HoursColumnIEnumerable
    {
        get
        {
            DateTime hour = DateTime.ParseExact("08:00", "hh:mm", CultureInfo.InvariantCulture);
            string returnString = string.Empty;
            for (int i = 0; i <= 23; i++)
            {
                returnString = hour.ToShortTimeString();
                hour = hour.AddMinutes(30);
                returnString += " - " + hour.ToShortTimeString();
                yield return returnString;
            }
        }
    }

    string[] Meses = new string[]
    {
        "", "Janeiro", "Fevereiro", "Março", "Abril", "Maio", "Junho",
        "Julho", "Agosto", "Setembro", "Outubro", "Novembro", "Dezembro"
    };

    string[] DiaSemana = new string[]
    {
        "Dom", "2ª F", "3ª F", "4ª F", "5ª F", "6ª F", "Sáb"
    };
}