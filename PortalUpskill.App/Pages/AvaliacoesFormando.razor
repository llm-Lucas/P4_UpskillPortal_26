@page "/AvaliacoesFormando"

@inject IFormandoData formandoData
@inject IModuloData moduloData
@inject ProtectedSessionStorage sessionStorage
@inject FileManagerService FileMngSrv
@inject IJSRuntime JSRuntime

@using Newtonsoft.Json

<div class="cardstyle">
    @if (formando != null && formando.Id != 0)
    {
        <span>Nome Completo:</span>
        <h2>@formando.Nome</h2>

        <br />

        @if (formando.CV != null)
        {
            <RadzenButton Text="Download CV"
                          Click="@VisualizarCV"
                          Style="margin-bottom:20px" />
        }

        <br />

        <span class="material-icons" style="vertical-align: middle; padding-top:-3px; color:blue;">email</span>
        <a href="@email">Enviar email</a>

        <hr />

        <h3>Situação Académica</h3>

        @if (formando.Turma != null)
        {
            <p><b>Curso:</b> @formando.Turma.Curso.Nome</p>
            <p><b>Turma:</b> @formando.Turma.Nome</p>
            <p><b>Data de Início:</b> @String.Format("{0:d}", formando.Turma.DataInicioCurso)</p>
            <p><b>Data de Fim:</b> @String.Format("{0:d}", formando.Turma.DataFimCurso)</p>

            <p><b>Módulos:</b></p>
            <ul>
                @foreach (Modulo modulo in modulos)
                {
                    string sigla = $"M{modulo.Id}";
                    <li><b>@sigla</b> - @modulo.Nome - @modulo.Formador.Nome</li>
                }
            </ul>

            <hr />

            <h3>Nota Final</h3>

            <RadzenGrid Data="@formandos"
                        TItem="Formando"
                        AllowSorting="false"
                        AllowFiltering="false"
                        AllowPaging="false">

                <Columns>

                    <RadzenGridColumn TItem="Formando" Title="FJ%">
                        <Template Context="Formando">
                            @if (Formando.FaltaJustificadas != null)
                            {
                                <span>@((Formando.FaltaJustificadas.Duracao / 60.0 / Formando.Turma.Curso.DuracaoHoras * 100).ToString("0.##"))%</span>
                            }
                            else
                            {
                                <span>0%</span>
                            }
                        </Template>
                    </RadzenGridColumn>

                    <RadzenGridColumn TItem="Formando" Title="FI%">
                        <Template Context="Formando">
                            @if (Formando.FaltaInjustificadas != null)
                            {
                                <span>@((Formando.FaltaInjustificadas.Duracao / 60.0 / Formando.Turma.Curso.DuracaoHoras * 100).ToString("0.##"))%</span>
                            }
                            else
                            {
                                <span>0%</span>
                            }
                        </Template>
                    </RadzenGridColumn>

                    @for (int i = 0; i < modulos.Count(); i++)
                    {
                        int index = i;
                        string title = $"Média M{modulos[index].Id}";

                        <RadzenGridColumn TItem="Formando" Title="@title">
                            <Template Context="Formando">
                                @if (Formando.DictAvaliacaoModular.Count() != 0)
                                {
                                    @if (Formando.DictAvaliacaoModular.ContainsKey(modulos[index].Id)
                                   && Formando.DictAvaliacaoModular[modulos[index].Id].NotaFinal >= 10)
                                    {
                                        <span style='color:green'>
                                            @(Formando.DictAvaliacaoModular[modulos[index].Id].NotaFinal.ToString("0.##"))
                                        </span>
                                    }
                                    else if (Formando.DictAvaliacaoModular.ContainsKey(modulos[index].Id)
                                    && Formando.DictAvaliacaoModular[modulos[index].Id].NotaFinal < 10)
                                    {
                                        <span style='color:red'>
                                            @(Formando.DictAvaliacaoModular[modulos[index].Id].NotaFinal.ToString("0.##"))
                                        </span>
                                    }
                                    else
                                    {
                                        <span>Sem nota</span>
                                    }
                                }
                                else
                                {
                                    <span>Sem nota</span>
                                }
                            </Template>
                        </RadzenGridColumn>
                    }

                    <RadzenGridColumn TItem="Formando" Title="Nota Final">
                        <Template Context="Formando">
                            @if (Formando.AvaliacaoFinal != null && Formando.AvaliacaoFinal.NotaFinal >= 10)
                            {
                                <span style='color:darkgreen'>
                                    @(Formando.AvaliacaoFinal.NotaFinal.ToString("0.##"))
                                </span>
                            }
                            else if (Formando.AvaliacaoFinal != null && Formando.AvaliacaoFinal.NotaFinal < 10)
                            {
                                <span style='color:red'>
                                    @(Formando.AvaliacaoFinal.NotaFinal.ToString("0.##"))
                                </span>
                            }
                            else
                            {
                                <span>Sem nota</span>
                            }
                        </Template>
                    </RadzenGridColumn>
                     
                </Columns>
            </RadzenGrid>

            <hr />

            <h3>Notas de Módulos</h3>

            <RadzenGrid Data="@modulos"
                        TItem="Modulo"
                        AllowSorting="false"
                        AllowFiltering="false"
                        AllowPaging="false">
                <Columns>
                    <RadzenGridColumn TItem="Modulo" Title="Módulo">
                        <Template Context="modulo">
                            <span>@($"M{modulo.Id}") - @modulo.Nome</span>
                        </Template>
                    </RadzenGridColumn>

                    <RadzenGridColumn TItem="Modulo" Title="Formador">
                        <Template Context="modulo">
                            @modulo.Formador.Nome
                        </Template>
                    </RadzenGridColumn>

                    <RadzenGridColumn TItem="Modulo" Title="Nota Final do Módulo">
                        <Template Context="modulo">
                            @if (formandoNota.DictAvaliacaoModular != null &&
                                                formandoNota.DictAvaliacaoModular.ContainsKey(modulo.Id))
                            {
                                var avaliacao = formandoNota.DictAvaliacaoModular[modulo.Id];

                                if (avaliacao.NotaFinal >= 10)
                                {
                                    <span style="color:green">@avaliacao.NotaFinal.ToString("0.##")</span>
                                }
                                else
                                {
                                    <span style="color:red">@avaliacao.NotaFinal.ToString("0.##")</span>
                                }
                            }
                            else
                            {
                                <span>Sem nota</span>
                            }
                        </Template>
                    </RadzenGridColumn>

                    <RadzenGridColumn TItem="Modulo" Title="Comentários">
                        <Template Context="modulo">
                            @if (formandoNota.DictAvaliacaoModular != null &&
                                                formandoNota.DictAvaliacaoModular.ContainsKey(modulo.Id) &&
                                                !string.IsNullOrEmpty(formandoNota.DictAvaliacaoModular[modulo.Id].Comentarios))
                            {
                                <span>@formandoNota.DictAvaliacaoModular[modulo.Id].Comentarios</span>
                            }
                            else
                            {
                                <span>Sem comentários</span>
                            }
                        </Template>
                    </RadzenGridColumn>
                </Columns>
            </RadzenGrid>

            <hr />

            <h3>Histórico do Formando</h3>

            <RadzenGrid AllowFiltering="true"
                        AllowPaging="true"
                        AllowSorting="true"
                        FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                        Data="@historicoFormando"
                        TItem="EstadosFormando"
                        ColumnWidth="200px">
                <Columns>
                    <RadzenGridColumn TItem="EstadosFormando" Property="Estado.Nome" Title="Estado" />
                    <RadzenGridColumn TItem="EstadosFormando" Property="Data" Title="Data">
                        <Template Context="EstadosFormando">
                            @String.Format("{0:d}", EstadosFormando.Data)
                        </Template>
                    </RadzenGridColumn>
                    <RadzenGridColumn TItem="EstadosFormando" Property="Observacoes" Title="Observações" />
                </Columns>
            </RadzenGrid>

            <hr />

            <h3>Contactos</h3>
            <p><b>Email:</b> @formando.Email</p>
            <p><b>Contacto Telemóvel:</b> @formando.ContactoTelemovel</p>
        }
        else
        {
            <h5>O formando ainda não está associado a uma Turma.</h5>
        }
    }
</div>

<div class="row justify-content-center">
    <div class="col-md-12 d-flex align-items-end justify-content-center" style="margin-top: 16px;">
        <RadzenButton ButtonStyle="ButtonStyle.Secondary"
                      Icon="cancel"
                      Text="Voltar"
                      Click="@(() => navManager.NavigateTo("Index"))" />
    </div>
</div>

@code {
    Pessoa user;
    Formando formando = new Formando();
    Formando formandoNota = new Formando();

    List<Formando> formandos = new List<Formando>();
    List<Modulo> modulos = new List<Modulo>();
    List<EstadosFormando> historicoFormando = new List<EstadosFormando>();

    string email;

    protected override async Task OnInitializedAsync()
    {
        var readUserFromSession = await sessionStorage.GetAsync<string>("user");

        if (readUserFromSession.Success)
        {
            user = JsonConvert.DeserializeObject<Pessoa>(readUserFromSession.Value);

            formando = formandoData.GetById(user.Id);

            if (formando != null)
            {
                email = $"mailto:{formando.Email}";
                historicoFormando = formandoData.ObterHistoricoDoFormando(formando.Id);

                if (formando.Turma != null)
                {
                    modulos = moduloData.GetModulosComFormadorByTurma(formando.Turma.Id);
                    modulos = modulos.OrderBy(m => m.Id).ToList();

                    formandos = formandoData.GetAllByTurmaWithAvaliacao(formando.Turma.Id)
                        .Where(f => f.Id == formando.Id)
                        .ToList();

                    if (formandos.Count > 0)
                    {
                        formandoNota = formandos.First();
                    }
                }
            }
        }
    }

    public async void VisualizarCV()
    {
        await JSRuntime.InvokeAsync<object>("open", new CancellationToken(), $"CV/{formando.Id}", "_blank");
    }
}