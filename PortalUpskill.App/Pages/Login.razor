@attribute [AllowAnonymous]
@layout LoginLayout
@page "/"
@using UpskillPortal.Utils
@using BCrypt.Net

@inject AuthenticationStateProvider authStateProvider
@inject ProtectedSessionStorage sessionStorage
@inject IPessoaData pessoaData

<h2>Login</h2>
<EditForm class="col-8 m-auto" Model="loginVM" OnValidSubmit="ValidateUser">
    <DataAnnotationsValidator/>
    <div class="form-group">
            <RadzenLabel Text="Email" />
            <RadzenTextBox class="form-control" @bind-Value="@loginVM.Email" />
            <ValidationMessage For="@(() => loginVM.Email)"/>
    </div>
    <div class="form-group">
            <RadzenLabel Text="Password" />
@*             <RadzenPassword class="form-control" @bind-Value="@loginVM.Password" />
 *@            
        <div style="position: relative;">
    <input type="@(showPassword ? "text" : "password")"
           class="form-control"
           @bind="loginVM.Password"
           placeholder="Password"
           style="padding-right: 2.5rem;" />
            <button type="button"
                    @onclick="TogglePasswordVisibility"
                    title="@(showPassword ? "Ocultar password" : "Mostrar password")"
                    style="position: absolute; right: 0.5rem; top: 50%; transform: translateY(-50%);
                background: none; border: none; padding: 0; cursor: pointer; outline: none;">
                <i class="@(showPassword ? "oi oi-lock-locked" : "oi oi-eye")"></i>
            </button>
        </div>
            <ValidationMessage For="@(() => loginVM.Password)" />
    </div>
    <div class="mt-2 text-center">
        <a href="/RecuperarPassword">Esqueci-me da password</a>
    </div>
    <RadzenButton class="my-2" ButtonType="ButtonType.Submit" ButtonStyle="ButtonStyle.Success" Icon="login" Text="Log in" />
</EditForm>

@code {

    LoginViewModel loginVM = new LoginViewModel();

    private bool showPassword = false;

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }

    [CascadingParameter]
    Task<AuthenticationState> AuthenticationStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateTask;
        if (authState.User.Identity.IsAuthenticated)
        {
            navManager.NavigateTo("Index");
        }
    }

    async Task ValidateUser()
    {
        var pessoa = pessoaData.GetByEmail(loginVM.Email);

        if (pessoa != null)
        {
            bool passwordCorreta = false;

            if (pessoa.Password.StartsWith("$2a$") || pessoa.Password.StartsWith("$2b$"))
            {
                // passwords antigas com BCrypt
                passwordCorreta = BCrypt.Verify(loginVM.Password, pessoa.Password);
            }
            else
            {
                try
                {
                    // passwords com HashingService (PBKDF2)
                    passwordCorreta = HashingService.CompareHash(pessoa.Password, loginVM.Password);
                }
                catch
                {
                    // fallback para passwords em texto simples (contas de teste)
                    passwordCorreta = loginVM.Password == pessoa.Password;
                }
            }

            if (passwordCorreta && pessoa.Perfil.Nome != null)
            {
                ((UpskillAuthenticationStateProvider)authStateProvider).MarkUserAsAuthenticated(pessoa);
                navManager.NavigateTo("Index");

                string userJson = JsonConvert.SerializeObject(pessoa);
                await sessionStorage.SetAsync("user", userJson);
            }
            else
            {
                notificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Password errada", Duration = 4000 });
            }
        }
        else
        {
            notificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Email não encontrado", Duration = 4000 });
        }
    }
}
