    List<Formando> formandos = new();
    List<Aula> tabelaSumrios = new();
    List<Modulo> modulos = new();
    List<Turma> turmas = new();

    List<ListaInfoRel> relatoriosFixos = new()
    {
        new ListaInfoRel { Id = 1, Nome = "Faltas" },
        new ListaInfoRel { Id = 2, Nome = "Sumários" }
