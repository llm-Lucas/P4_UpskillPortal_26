    List<ListaMeses> mesesFixos = new()
    {
        new ListaMeses { Id = 1,  Nome = "Janeiro" },
        new ListaMeses { Id = 2,  Nome = "Fevereiro" },
        new ListaMeses { Id = 3,  Nome = "Março" },
        new ListaMeses { Id = 4,  Nome = "Abril" },
        new ListaMeses { Id = 5,  Nome = "Maio" },
        new ListaMeses { Id = 6,  Nome = "Junho" },
        new ListaMeses { Id = 7,  Nome = "Julho" },
        new ListaMeses { Id = 8,  Nome = "Agosto" },
        new ListaMeses { Id = 9,  Nome = "Setembro" },
        new ListaMeses { Id = 10, Nome = "Outubro" },
        new ListaMeses { Id = 11, Nome = "Novembro" },
        new ListaMeses { Id = 12, Nome = "Dezembro" },
        new ListaMeses { Id = 13, Nome = "Todos" }
    };

    int SelectedModuloId;
    int SelectedTurmaId;
    int SelectedRelatorio; // 0 = ecrã inicial, 1 = Faltas, 2 = Sumários
    int SelectedMes;
    Turma SelectedTurma;

    List<Aula> aulas = new();
    Dictionary<int, double> HorasPorModulo = new();
    Dictionary<int, Formador> FormadoresTurma = new();
    bool changesMade = false;

    #region VariaveisSfScheduler
    SfSchedule<AppointmentData> Scheduler;
    SfTextBox SubjectRef;
    SfTextBox DescriptionRef;
    SfDropDownList<int, ResourceData> EventTypeRef;
    View CurrentView = View.TimelineYear;
    DateTime CurrentDate = DateTime.Now;
    List<AppointmentData> DataSource = new();
    List<ResourceData> OwnerData = new();
    List<SelectResourceItem> SelectResourceList = new();
    #endregion

    protected override async Task OnInitializedAsync()
    {
        turmas = turmaData.GetAll();

        if (Id != 0)
        {
            SelectedTurmaId = Id;
            OnTurmaSelected();
        }
    }

    void EscolherRelatorio(int tipo)
    {
        SelectedRelatorio = tipo;
        formandos = new();
        tabelaSumrios = new();
        SelectedTurmaId = 0;
        SelectedTurma = null;
        SelectedMes = 0;
        SelectedModuloId = 0;
    }

    void VoltarAoInicio()
    {
        SelectedRelatorio = 0;
        formandos = new();
        tabelaSumrios = new();
        SelectedTurmaId = 0;
        SelectedTurma = null;
        SelectedMes = 0;
        SelectedModuloId = 0;
    }

    void OnTurmaSelected()
    {
        DataSource.Clear();
        formandos = new();
        tabelaSumrios = new();
        SelectedMes = 0;
        SelectedModuloId = 0;

        SelectedTurma = turmas.Single(t => t.Id == SelectedTurmaId);
        SelectedTurma.Curso = cursoData.GetById(SelectedTurma.CursoId.Value);
        SelectedTurma.Modulos = moduloData.GetModulosComFormadorByTurma(SelectedTurmaId);

        modulos = moduloData.GetModulosComFormadorByTurma(SelectedTurmaId);

        var result = moduloData.GetModuloFormadorByTurma(SelectedTurma);
        foreach (var moduloHora in SelectedTurma.Curso.Modulos)
        {
            SelectedTurma.Curso.Modulos[moduloHora.Key] = result[moduloHora.Key.Id].Horas;
        }

        SelectedTurma.Aulas = aulaData.GetByTurma(SelectedTurma);
        CurrentDate = SelectedTurma.DataInicioCurso.Value;
    }

    void OnMesSelected()
    {
        if (SelectedTurma == null) return;

        // formandos = formandoData.GetByTurma(SelectedTurmaId);

        // foreach (var formando in formandos)
        // {
        //     var faltas = faltaData.GetByFormando(formando.Id);

        //     if (SelectedMes != 13)
        //         faltas = faltas.Where(f => f.DataHora.Month == SelectedMes).ToList();

        //     formando.FaltaJustificadas = faltas.FirstOrDefault(f => f.Justificada == true);
        //     formando.FaltaInjustificadas = faltas.FirstOrDefault(f => f.Justificada == false);
        // }

        StateHasChanged();
    }

    void OnModuloSelected()
    {
        // if (SelectedTurma == null || SelectedModuloId == 0) return;

        // tabelaSumrios = aulaData.GetByTurmaAndModulo(SelectedTurmaId, SelectedModuloId);

        StateHasChanged();
    }

    public class ResourceData
    {
        public int Id { get; set; }
        public string Text { get; set; }
        public string Color { get; set; }
        public int ModuloId { get; set; }
    }

    public class SelectResourceItem
    {
        public int ModuloId { get; set; }
        public string Text { get; set; }
    }

    public class ListaInfo
    {
        public string Nome { get; set; }
    }

    public class ListaInfoRel
    {
        public int Id { get; set; }
        public string Nome { get; set; }
    }

    public class ListaMeses
    {
        public int Id { get; set; }
        public string Nome { get; set; }
    }
}