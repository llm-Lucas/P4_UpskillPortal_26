@page "/Relatorios"
@page "/Relatorios/{Id:int}"

@inject ITurmaData turmaData
@inject ICursoData cursoData
@inject IAulaData aulaData
@inject IFaltaData faltaData
@inject IFormadorData formadorData
@inject IFormandoData formandoData
@inject IPessoaData pessoaData
@inject IModuloData moduloData
@inject IPessoalData pessoalData
@inject NavigationManager navManager

@using Radzen

<div class="cardstyle">

    @* PASSO 1: Seleção da Turma *@
    @if (SelectedTurmaId == 0)
    {
        <h2>Relatórios</h2>
        <p class="text-muted">Por favor, selecione a turma que pretende consultar para aceder aos relatórios.</p>

        <div class="mt-4 mb-4">
            <label class="fw-bold mb-2 d-block">Turma</label>
            <RadzenDropDown class="w-50 d-block"
                            Data="@turmas"
                            @bind-Value="SelectedTurmaId"
                            Change="OnTurmaSelected"
                            TValue="int"
                            ValueProperty="Id"
                            TextProperty="Nome"
                            AllowFiltering="true"
                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                            AllowClear="false">
                <Template Context="Turma">
                    <span>@Turma.Nome - @(Turma.Curso?.Nome ?? "Sem Curso")</span>
                </Template>
            </RadzenDropDown>
        </div>

        <div class="row mt-3">
            <div class="col-md-12">
                <RadzenButton ButtonStyle="ButtonStyle.Secondary" Icon="cancel" Text="Voltar" Click="@(() => navManager.NavigateTo("Index"))" />
            </div>
        </div>
    }
    @* PASSO 2: Seleção do Tipo de Relatório *@
    else if (SelectedRelatorio == 0)
    {
        <h2>Relatórios - @SelectedTurma?.Nome</h2>
        <p class="text-muted">Selecione o tipo de relatório que pretende consultar para esta turma.</p>

        <div class="row mt-4 justify-content-center">
            <div class="col-md-4 text-center d-flex justify-content-center">
                <a class="corbotao hvr-underline-from-left c-pointer" @onclick="() => EscolherRelatorio(1)" role="button">
                    <span class="oi oi-people" style="font-size: 48px; margin-top: 5px;"></span>
                    <span class="texto-card">FALTAS</span>
                </a>
            </div>

            <div class="col-md-4 text-center d-flex justify-content-center">
                <a class="corbotao hvr-underline-from-right c-pointer" @onclick="() => EscolherRelatorio(2)" role="button">
                    <span class="oi oi-document" style="font-size: 48px; margin-top: 5px;"></span>
                    <span class="texto-card">SUMÁRIOS</span>
                </a>
            </div>
        </div>

        <div class="row justify-content-center mt-5">
            <div class="col-md-12 text-center">
                <RadzenButton ButtonStyle="ButtonStyle.Light" Icon="arrow_back" Text="Escolher Outra Turma" Click="VoltarAoInicio" />
            </div>
        </div>
    }
    @* PASSO 3: Visualização do Relatório *@
    else
    {
        <div class="mb-4 d-flex justify-content-between align-items-center bg-light p-3 rounded">
            <RadzenButton ButtonStyle="ButtonStyle.Secondary" Icon="arrow_back" Text="Voltar" Click="VoltarParaSelecao" />
            <span class="fs-5 fw-bold text-dark">Turma Atual: <span class="text-primary">@SelectedTurma?.Nome</span></span>
        </div>

        @* SUBPÁGINA: FALTAS *@
        @if (SelectedRelatorio == 1)
        {
            <RadzenGrid @ref="grid"
                        Data="@formandosDaTurma"
                        TItem="PortalUpskill.Data.Models.Formando"
                        AllowSorting="true"
                        AllowFiltering="false"
                        FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                        AllowPaging="true"
                        PageSize="@pageSize"
                        ExpandMode="@DataGridExpandMode.Single">

                @* subgrid de detalhe das faltas *@
                <Template Context="formando">
                    @{
                        var faltas = faltasPorFormando.ContainsKey(formando.Id)
                                     ? faltasPorFormando[formando.Id]
                                     : new List<FaltaDisplay>();
                    }
                    @if (!faltas.Any())
                    {
                        <p class="text-muted ms-3 mt-2">Sem faltas registadas.</p>
                    }
                    else
                    {
                        <div class="ms-3 mt-2 mb-2">
                            <RadzenGrid Data="@faltas"
                                        TItem="FaltaDisplay"
                                        AllowPaging="true"
                                        PageSize="5"
                                        AllowSorting="true"
                                        Style="width:100%">
                                <Columns>
                                    <RadzenGridColumn TItem="FaltaDisplay" Property="Data" Title="Data" Width="140px">
                                        <Template Context="f">
                                            @f.Data.ToString("dd/MM/yyyy")
                                        </Template>
                                    </RadzenGridColumn>

                                    <RadzenGridColumn TItem="FaltaDisplay" Property="Tipo" Title="Tipo" Width="160px">
                                        <Template Context="f">
                                            <span style="color: @(f.Tipo == "Justificada" ? "green" : "red"); font-weight:600">
                                                @f.Tipo
                                            </span>
                                        </Template>
                                    </RadzenGridColumn>

                                    <RadzenGridColumn TItem="FaltaDisplay" Property="Duracao" Title="Duração (min)" Width="140px" />
                                </Columns>
                            </RadzenGrid>
                        </div>
                    }
                </Template>

                <Columns>
                    <RadzenGridColumn TItem="PortalUpskill.Data.Models.Formando" Property="Nome" Title="Nome do Formando" />

                    <RadzenGridColumn TItem="PortalUpskill.Data.Models.Formando" Title="Faltas Justificadas"
                                      Bubble="false" Filterable="false" Sortable="false"
                                      TextAlign="TextAlign.Center" Width="200px">
                        <Template Context="formando">
                            <span class="text-success fw-bold">@ObterContagemFaltas(formando.Id, true)</span>
                        </Template>
                    </RadzenGridColumn>

                    <RadzenGridColumn TItem="PortalUpskill.Data.Models.Formando" Title="Faltas Injustificadas"
                                      Bubble="false" Filterable="false" Sortable="false"
                                      TextAlign="TextAlign.Center" Width="200px">
                        <Template Context="formando">
                            <span class="text-danger fw-bold">@ObterContagemFaltas(formando.Id, false)</span>
                        </Template>
                    </RadzenGridColumn>
                </Columns>
            </RadzenGrid>
        }

        @* SUBPÁGINA: SUMÁRIOS *@
        @if (SelectedRelatorio == 2)
        {
            <div class="mt-4">
                <h4 class="mb-3"><span class="oi oi-document me-2 text-primary"></span> Relatório de Sumários da Turma</h4>

                <div style="margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
                    <span>Itens por página:</span>
                    <RadzenDropDown @bind-Value="@pageSize"
                                    Data="@(new int[] { 10, 15, 20, 50 })"
                                    Change="@(() => Grid.Reload())"
                                    Style="width: 80px" />
                </div>

                <RadzenGrid @ref="Grid"
                            Data="@aulasDaTurma"
                            TItem="PortalUpskill.Data.Models.Aula"
                            AllowSorting="true"
                            AllowFiltering="false"
                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                            AllowPaging="true"
                            PageSize="@pageSize">
                    <Columns>
                        <RadzenGridColumn TItem="PortalUpskill.Data.Models.Aula" Property="HoraInicio" Title="Data / Hora" Width="220px">
                            <Template Context="aula">
                                @aula.HoraInicio.ToString("dd/MM/yyyy HH:mm")
                            </Template>
                        </RadzenGridColumn>

                        <RadzenGridColumn TItem="PortalUpskill.Data.Models.Aula" Property="DuracaoHoras" Title="Duração" TextAlign="TextAlign.Center" Width="120px" Sortable="false">
                            <Template Context="aula">
                                @aula.DuracaoHoras h
                            </Template>
                        </RadzenGridColumn>

                        <RadzenGridColumn TItem="PortalUpskill.Data.Models.Aula" Property="Sumario" Title="Sumário" Sortable="false">
                            <Template Context="aula">
                                <span style="white-space: pre-line;">@aula.Sumario</span>
                            </Template>
                        </RadzenGridColumn>
                    </Columns>
                </RadzenGrid>
            </div>
        }
    }
</div>

@code {
    [Parameter] public int Id { get; set; }
    [Parameter] public int Idf { get; set; }
    [Parameter] public int Idt { get; set; }
    [Parameter] public string? source { get; set; }
    [Parameter] public Func<Pessoal, bool> Filter { get; set; }
    [Parameter] public int Tipo { get; set; }

    RadzenGrid<Formando> grid;
    RadzenGrid<Aula> Grid;
    int pageSize = 10;

    List<Formando> formandos = new();
    List<Aula> tabelaSumrios = new();
    List<Modulo> modulos = new();
    List<Turma> turmas = new();

    private List<PortalUpskill.Data.Models.Formando> formandosDaTurma = new();
    private List<PortalUpskill.Data.Models.Aula> aulasDaTurma = new();

    private Dictionary<int, (int Justificadas, int Injustificadas)> resumoFaltas = new();
    private Dictionary<int, List<FaltaDisplay>> faltasPorFormando = new();

    public class FaltaDisplay
    {
        public DateTime Data { get; set; }
        public string Tipo { get; set; }
        public int Duracao { get; set; }
    }

    int SelectedModuloId;
    int SelectedTurmaId;
    int SelectedRelatorio; // 0 = ecrã inicial, 1 = Faltas, 2 = Sumários
    int SelectedMes;
    Turma SelectedTurma;

    List<Aula> aulas = new();
    Dictionary<int, double> HorasPorModulo = new();
    Dictionary<int, Formador> FormadoresTurma = new();
    bool changesMade = false;

    protected override async Task OnInitializedAsync()
    {
        turmas = turmaData.GetAll();
        if (Id != 0)
        {
            SelectedTurmaId = Id;
            OnTurmaSelected();
        }
    }

    private void OnTurmaSelected()
    {
        if (SelectedTurmaId == 0) return;

        formandos = new();
        tabelaSumrios = new();
        SelectedMes = 0;
        SelectedModuloId = 0;

        SelectedTurma = turmas.SingleOrDefault(t => t.Id == SelectedTurmaId);
        if (SelectedTurma != null)
        {
            SelectedTurma.Curso = cursoData.GetById(SelectedTurma.CursoId.Value);
            SelectedTurma.Modulos = moduloData.GetModulosComFormadorByTurma(SelectedTurmaId);
            modulos = moduloData.GetModulosComFormadorByTurma(SelectedTurmaId);

            var result = moduloData.GetModuloFormadorByTurma(SelectedTurma);
            foreach (var moduloHora in SelectedTurma.Curso.Modulos)
            {
                SelectedTurma.Curso.Modulos[moduloHora.Key] = result[moduloHora.Key.Id].Horas;
            }

            SelectedTurma.Aulas = aulaData.GetByTurma(SelectedTurma);
        }
    }

    private void EscolherRelatorio(int tipo)
    {
        SelectedRelatorio = tipo;

        if (SelectedRelatorio == 1)
        {
            // Toda a recolha de dados pesada foi movida para aqui!
            formandosDaTurma = formandoData.GetAllByTurma(SelectedTurmaId);
            resumoFaltas.Clear();
            faltasPorFormando.Clear();

            foreach (var f in formandosDaTurma)
            {
                var historicoFaltas = faltaData.GetByFormandoId(f.Id);

                resumoFaltas[f.Id] = (
                    historicoFaltas.Count(x => x.Justificada == true),
                    historicoFaltas.Count(x => x.Justificada == false)
                );

                faltasPorFormando[f.Id] = historicoFaltas
                    .OrderByDescending(x => x.HoraInicio)
                    .Select(x => new FaltaDisplay
                    {
                        Data = x.HoraInicio.Date,
                        Tipo = x.Justificada ? "Justificada" : "Injustificada",
                        Duracao = x.Duracao
                    }).ToList();
            }
        }
        else if (SelectedRelatorio == 2)
        {
            aulasDaTurma = aulaData.GetByTurma(SelectedTurmaId);
        }

        StateHasChanged();
    }

    private int ObterContagemFaltas(int formandoId, bool buscarJustificadas)
    {
        if (resumoFaltas.TryGetValue(formandoId, out var contagem))
        {
            return buscarJustificadas ? contagem.Justificadas : contagem.Injustificadas;
        }
        return 0;
    }

    private void VoltarParaSelecao()
    {
        SelectedRelatorio = 0;
        StateHasChanged();
    }

    private void VoltarAoInicio()
    {
        SelectedRelatorio = 0;
        SelectedTurmaId = 0;
        SelectedTurma = null;
        formandosDaTurma = new();
        aulasDaTurma = new();
        resumoFaltas.Clear();
        faltasPorFormando.Clear();
        SelectedMes = 0;
        SelectedModuloId = 0;
    }
}