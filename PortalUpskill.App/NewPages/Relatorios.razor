@page "/Relatorios"

@inject ITurmaData turmaData
@inject ICursoData cursoData
@inject IAulaData aulaData
@inject IFaltaData faltaData
@inject IFormadorData formadorData
@inject IFormandoData formandoData
@inject IPessoaData pessoaData
@inject IModuloData moduloData
@inject IPessoalData pessoalData

@using Radzen

<div class="cardstyle">

    @if (SelectedRelatorio == 0)
    {
        <h2>Relatórios</h2>
        <p class="text-muted">Selecione o tipo de relatório que pretende consultar.</p>

        <div class="row mt-3 justify-content-center">
            <div class="col-md-4 text-center d-flex justify-content-center">
                <a class="corbotao hvr-underline-from-left c-pointer" @onclick="() => EscolherRelatorio(1)" role="button">
                    <span class="oi oi-people" style="font-size: 48px; margin-top: 5px;"></span>
                    <span class="texto-card">FALTAS</span>
                </a>
            </div>

            <div class="col-md-4 text-center d-flex justify-content-center">
                <a class="corbotao hvr-underline-from-right c-pointer" @onclick="() => EscolherRelatorio(2)" role="button">
                    <span class="oi oi-document" style="font-size: 48px; margin-top: 5px;"></span>
                    <span class="texto-card">SUMÁRIOS</span>
                </a>
            </div>
        </div>

        <div class="row justify-content-center mt-3">
            <div class="col-md-12 d-flex align-items-end justify-content-center">
                <RadzenButton ButtonStyle="ButtonStyle.Secondary" Icon="cancel"
                              style="display: inline-block; margin-left: 10px;"
                              Text="Voltar" Click="@(() => navManager.NavigateTo($"Index"))" />
            </div>
        </div>
    }
    else
    {
        <div class="mb-3">
            <RadzenButton ButtonStyle="ButtonStyle.Light" Icon="arrow_back" Text="Voltar aos relatórios" Click="VoltarAoInicio" />
        </div>

        <h2>@(SelectedRelatorio == 1 ? "Relatório de Faltas" : "Relatório de Sumários")</h2>

        <div class="mt-3">
            <label>Turma</label>
            <RadzenDropDown class="w-25 d-block" Data="@turmas" @bind-Value="SelectedTurmaId" Change="OnTurmaSelected"
                            TValue="int" ValueProperty="Id" TextProperty="Nome"
                            AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                            AllowClear="false">
                <Template Context="Turma">
                    <span>@Turma.Nome - @Turma.Curso.Nome</span>
                </Template>
            </RadzenDropDown>
        </div>

        @if (SelectedRelatorio == 1 && SelectedTurma != null)
        {
            <div class="mt-3">
                <label>Mês</label>
                <RadzenDropDown class="w-25 d-block" Data="@mesesFixos" @bind-Value="SelectedMes" Change="OnMesSelected"
                                TValue="int" ValueProperty="Id" TextProperty="Nome"
                                AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                AllowClear="false">
                </RadzenDropDown>
            </div>

            @if (SelectedMes != 0 && formandos != null && formandos.Any())
            {
                <div class="row justify-content-end mt-2">
                    <div class="col-auto">
                        <RadzenButton Text="Excel" Icon="grid_on" Style="margin-bottom:20px" />
                    </div>
                </div>
                <RadzenGrid Data="@formandos" TItem="Formando"
                            AllowSorting="true" AllowFiltering="true"
                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                            AllowPaging="true" PageSize="10">
                    <Columns>
                        <RadzenGridColumn TItem="Formando" Property="Nome" Title="Nome" />
                        <RadzenGridColumn TItem="Formando" Title="FJ*" Sortable="false">
                            <Template Context="Formando">
                                @if (Formando.FaltaJustificadas != null)
                                {
                                    <span>@((Formando.FaltaJustificadas.Duracao / 60.0 / Formando.Turma.Curso.DuracaoHoras * 100).ToString("0.##"))%</span>
                                }
                                else
                                {
                                    <span>0%</span>
                                }
                            </Template>
                            <FooterTemplate><i>*Faltas Justificadas</i></FooterTemplate>
                        </RadzenGridColumn>
                        <RadzenGridColumn TItem="Formando" Title="FI*" Sortable="false">
                            <Template Context="Formando">
                                @if (Formando.FaltaInjustificadas != null)
                                {
                                    <span>@((Formando.FaltaInjustificadas.Duracao / 60.0 / Formando.Turma.Curso.DuracaoHoras * 100).ToString("0.##"))%</span>
                                }
                                else
                                {
                                    <span>0%</span>
                                }
                            </Template>
                            <FooterTemplate><i>*Faltas Injustificadas</i></FooterTemplate>
                        </RadzenGridColumn>

                        @for (int i = 0; i < modulos.Count(); i++)
                        {
                            int index = i;
                            string title = $"Média M{modulos[index].Id}";
                            <RadzenGridColumn TItem="Formando" Property="" Title="@title" Sortable="false">
                                <Template Context="Formando">
                                    @if (Formando.DictAvaliacaoModular != null && Formando.DictAvaliacaoModular.ContainsKey(modulos[index].Id))
                                    {
                                        var nota = Formando.DictAvaliacaoModular[modulos[index].Id].NotaFinal;
                                        <span style="color:@(nota >= 10 ? "green" : "red")">@nota.ToString("0.##")</span>
                                    }
                                    else
                                    {
                                        <span>Sem nota</span>
                                    }
                                </Template>
                            </RadzenGridColumn>
                        }

                        <RadzenGridColumn TItem="Formando" Title="Detalhes" Sortable="false" Filterable="false">
                            <Template Context="Formando">
                                <RadzenButton Title="Ver detalhes" Size="ButtonSize.Medium" Icon="description"
                                              Click=@(args => dialogService.Open<DetalhesFormando>($"Detalhes",
                                                                                      new Dictionary<string, object>() { { "FormandoId", Formando.Id } },
                                                                                      new DialogOptions() { Width = "80%", Height = "90%" })) />
                            </Template>
                        </RadzenGridColumn>
                    </Columns>
                </RadzenGrid>
            }
        }

        @if (SelectedRelatorio == 2 && SelectedTurma != null)
        {
            <div class="mt-3">
                <label>Módulo</label>
                <RadzenDropDown class="w-25 d-block"
                                Data="@SelectedTurma.Curso.Modulos.Keys.ToList()"
                                @bind-Value="SelectedModuloId"
                                Change="OnModuloSelected"
                                TValue="int" TextProperty="Nome" ValueProperty="Id"
                                AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                AllowClear="false">
                </RadzenDropDown>
            </div>

            @if (SelectedModuloId != 0 && tabelaSumrios != null && tabelaSumrios.Any())
            {
                <div class="row justify-content-end mt-2">
                    <div class="col-auto">
                        <RadzenButton Text="Excel" Icon="grid_on" Style="margin-bottom:20px" />
                    </div>
                </div>
                <RadzenGrid Data="@tabelaSumrios" TItem="Aula"
                            AllowSorting="true" AllowFiltering="true"
                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                            AllowPaging="true" PageSize="10">
                    <Columns>
                        <RadzenGridColumn TItem="Aula" Property="DataHoraInicio" Title="Início Data e Hora" />
                        <RadzenGridColumn TItem="Aula" Property="DataHoraFim" Title="Fim Data e Hora" />
                        <RadzenGridColumn TItem="Aula" Property="Sumario" Title="Sumário" />
                        <RadzenGridColumn TItem="Aula" Property="Formador.Nome" Title="Formador" />
                        <RadzenGridColumn TItem="Aula" Property="Sala" Title="Sala" />
                    </Columns>
                </RadzenGrid>
            }
        }
    }

    <br />
</div>

@code {

