    string email;
    string mail;
    /// <summary>
    /// Carrega a lista de formadores da BD
    /// </summary>
    void LoadPessoal()
    {
        staff = pessoalData.GetAll().Where(p => p.PerfilId == 1).OrderBy(p => p.Nome).ToList();

        if (Filter != null)
        {
            tabelaSumrios = staff.Where(Filter).OrderBy(p => p.Nome).ToList();
        }

        tabelaSumrios = staff;

        mail = "";

        foreach (var pessoal in tabelaSumrios)
        {
            mail = mail + pessoal.Email + ";";
        }

        email = $"mailto:{mail}";
    }

    void OnModuloSelected()
    {
        
        var moduloSelecionado = SelectedTurma.Curso.Modulos.Keys
