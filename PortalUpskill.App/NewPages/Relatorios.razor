@page "/Relatorios"

<!-- INÍCIO #004 -->
@inject ITurmaData turmaData
@inject ICursoData cursoData
@inject IAulaData aulaData
@inject IFaltaData faltaData
@inject IFormadorData formadorData
@inject IFormandoData formandoData
@inject IPessoaData pessoaData
@inject IModuloData moduloData
@inject IPessoalData pessoalData



@using Radzen

<div class="cardstyle">
    <h3>Selecione um ano letivo</h3>
    <RadzenDropDown class="w-25" Data="@listasFixas" @bind-Value="SelectedAnoLetivo" Change="OnAnoLetivoSelected" TValue="string" ValueProperty="Nome" TextProperty="Nome"
    AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
    AllowClear="false">
    </RadzenDropDown>

    @if (SelectedAnoLetivo != null)
    {
        <h3>Selecione uma turma</h3>
        <RadzenDropDown class="w-25" Data="@turmas" @bind-Value="SelectedTurmaId" Change="OnTurmaSelected" TValue="int" ValueProperty="Id" TextProperty="Nome"
        AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
        AllowClear="false">
            <Template Context="Turma">
                <span>@Turma.Nome - @Turma.Curso.Nome</span>
            </Template>
        </RadzenDropDown>
    }

    @if (SelectedTurma != null)
    {
        <h3>Selecione o tipo de relatório</h3>
        <RadzenDropDown class="w-25" Data="@relatoriosFixos" @bind-Value="SelectedRelatorio" Change="OnRelatorioSelected" TValue="int" ValueProperty="Id" TextProperty="Nome"
        AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
        AllowClear="false">
        </RadzenDropDown>
    }

    @if (SelectedRelatorio == 1)
    {   SelectedModuloId=0;
        <h3>Selecione o mês</h3>
        <RadzenDropDown class="w-25" Data="@mesesFixos" @bind-Value="SelectedMes" Change="OnMesSelected" TValue="int" ValueProperty="Id" TextProperty="Nome"
        AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
        AllowClear="false">
        </RadzenDropDown>

        @if (SelectedMes != 0)
        {   <!-- INICIO #004 -->
            <!-- falta a logica do botao -->
            <div class="row justify-content-center">
                <div class="col-md-12 d-flex align-items-end justify-content-center" style="margin-top: 16px;">
                    <RadzenButton Text="Excel" Icon="grid_on" Style="margin-bottom:20px" />
                </div>
            </div>
            <!-- FIM #004 -->
            <div class="cardstyle">
                <div class="row" style="margin-top:1em;">
                    <div class="col-md-12">
                        <h3>Formandos</h3>
                        <RadzenGrid Data="@formandos"
                        TItem="Formando"
                        AllowSorting="true"
                        AllowFiltering="true"
                        FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                        AllowPaging="true"
                        PageSize="10">
                            <Columns>
                                <RadzenGridColumn TItem="Formando" Property="Nome" Title="Nome" />
                                <RadzenGridColumn TItem="Formando" Title="FJ*" Sortable="false">
                                    <Template Context="Formando">
                                        @if (Formando.FaltaJustificadas != null)
                                        {
                                            <span>@((Formando.FaltaJustificadas.Duracao / 60.0 / Formando.Turma.Curso.DuracaoHoras * 100).ToString("0.##"))%</span>
                                        }
                                        else
                                        {
                                            <span>0%</span>
                                        }
                                    </Template>
                                    <FooterTemplate>
                                        <i>*Faltas Justificadas</i>
                                    </FooterTemplate>
                                </RadzenGridColumn>
                                <RadzenGridColumn TItem="Formando" Title="FI*" Sortable="false">
                                    <Template Context="Formando">
                                        @if (Formando.FaltaInjustificadas != null)
                                        {
                                            <span>@((Formando.FaltaInjustificadas.Duracao / 60.0 / Formando.Turma.Curso.DuracaoHoras * 100).ToString("0.##"))%</span>
                                        }
                                        else
                                        {
                                            <span>0% (Teste)</span>
                                        }
                                    </Template>
                                    <FooterTemplate>
                                        <i>*Faltas Injustificadas</i>
                                    </FooterTemplate>
                                </RadzenGridColumn>

                                @for (int i = 0; i < modulos.Count(); i++)
                                {
                                    int index = i;
                                    string title = $"Média M{modulos[index].Id}";

                                    <RadzenGridColumn TItem="Formando" Property="" Title="@title" Sortable="false">
                                        <Template Context="Formando">
                                            @if (Formando.DictAvaliacaoModular.Count() != 0)
                                            {
                                                @if (Formando.DictAvaliacaoModular.ContainsKey(modulos[index].Id) && Formando.DictAvaliacaoModular[modulos[index].Id].NotaFinal >= 10)
                                                {
                                                    <span style='color:green'>@(Formando.DictAvaliacaoModular[modulos[index].Id].NotaFinal.ToString("0.##"))</span>
                                                }
                                                else if (Formando.DictAvaliacaoModular.ContainsKey(modulos[index].Id) && Formando.DictAvaliacaoModular[modulos[index].Id].NotaFinal < 10)
                                                {
                                                    <span style='color:red'>@(Formando.DictAvaliacaoModular[modulos[index].Id].NotaFinal.ToString("0.##")) </span>
                                                }
                                                else
                                                {
                                                    <span>Sem nota</span>
                                                }
                                            }
                                            else
                                            {
                                                <span>Sem nota</span>
                                            }
                                        </Template>
                                    </RadzenGridColumn>
                                }


                                <RadzenGridColumn TItem="Formando" Title="Detalhes" Sortable="false" Filterable="false">
                                    <Template Context="Formando">
                                        <RadzenButton Title="Ver detalhes" Size="ButtonSize.Medium" Icon="description" Click=@(args => dialogService.Open<DetalhesFormando>($"Detalhes",
                                              new Dictionary<string, object>() { { "FormandoId", Formando.Id } },
                                              new DialogOptions(){ Width = "80%", Height = "90%" })) />
                                    </Template>
                                </RadzenGridColumn>
                            </Columns>
                        </RadzenGrid>
                    </div>
                </div>
            </div>
        }
    }
    else if (SelectedRelatorio == 2)
    {
        SelectedMes = 0;
        <h3>Selecione um módulo</h3>
        <RadzenDropDown class="w-25"
        Data="@SelectedTurma.Curso.Modulos.Keys.ToList()"
        @bind-Value="SelectedModuloId"
        Change="OnModuloSelected"
        TValue="int"
        TextProperty="Nome"
        ValueProperty="Id"
        AllowFiltering="true"
        FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
        AllowClear="false">
        </RadzenDropDown>
        if(SelectedModuloId != 0){
        <!-- INICIO #004 -->
        <!-- falta a logica do botao -->
        <div class="row justify-content-center">
            <div class="col-md-12 d-flex align-items-end justify-content-center" style="margin-top: 16px;">
                <RadzenButton Text="Excel" Icon="grid_on" Style="margin-bottom:20px" />
            </div>
        </div>

         <!-- alterar a logica e TItem -->
        <RadzenGrid Data="@tabelaSumrios"
                TItem="Pessoal"
                AllowSorting="true"
                AllowFiltering="true"
                FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                AllowPaging="true"
                PageSize="10">
            <Columns>
                <RadzenGridColumn TItem="Pessoal" Property="Nome" Title="Início Data e Hora" />
                <RadzenGridColumn TItem="Pessoal" Property="Email" Title="Fim Data e Hora" />
                <RadzenGridColumn TItem="Pessoal" Property="ContactoTelemovel" Title="Sumário" />
                <RadzenGridColumn TItem="Pessoal" Property="ContactoTelefone" Title="Formador" />
                    <RadzenGridColumn TItem="Pessoal" Property="Nacionalidade" Title="Sala" />
            </Columns>
        </RadzenGrid>
        }
        <!-- FIM #004 -->
    }



    <!-- Botão de Voltar -->
    <div class="row justify-content-center">
        <div class="col-md-12 d-flex align-items-end justify-content-center" style="margin-top: 16px;">
            <RadzenButton ButtonStyle="ButtonStyle.Secondary" Icon="cancel" style="display: inline-block; margin-left: 10px;" Text="Voltar" Click="@(() => navManager.NavigateTo($"Index"))" />
        </div>
    </div>
    <br />
</div>

